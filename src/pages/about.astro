---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout
	title="About Financial Decisions | Family-Owned Financial Planning"
	description="Learn about Financial Decisions, a family-owned financial planning firm serving Sudbury with independent advice and long-standing community roots."
>
	<main class="about-page page-shell overflow-x-clip">
		<section class="about-intro-section no-divider reveal" id="history" data-reveal-immediate>
			<div class="page-container page-container--content pt-10 pb-8 sm:pt-12 sm:pb-10">
				<div class="space-y-20 sm:space-y-24 lg:space-y-28">
					<section id="family-business" class="about-section about-section--opening">
						<div class="py-1 sm:py-2">
							<Hero
								variant="page"
								title="A Family Business"
								image="/images/Family.jpg"
								imageAlt="Family business team"
								imageWidth="407"
								imageHeight="314"
							>
								<div class="about-body-copy page-body max-w-[40rem]">
									Financial Decisions is locally owned and operated by the husband and wife
									team of
									<strong> John Lindsay and Linda Cartier and daughter Melanie Cartier.</strong>
									The firm recently received a 25 year membership plaque in the Greater
									Sudbury Chamber of Commerce. Linda is President of the company since its
									formation and has had extensive experience in the financial services
									industry and as a community volunteer together with her partners.
								</div>
							</Hero>
						</div>
					</section>

					<div>
						<section
							id="background"
							class="page-band page-band--soft relative left-1/2 my-10 w-[100dvw] -translate-x-1/2 sm:my-12 reveal"
						>
							<div class="page-container page-container--content py-7 sm:py-9">
								<div class="about-split about-split--portrait grid gap-8 md:grid-cols-[270px_minmax(0,1fr)] md:items-center md:gap-10">
									<div class="w-full md:pt-1">
										<div class="about-media-frame about-media-frame--portrait mx-auto w-full max-w-[270px] overflow-hidden rounded-lg md:mx-0 img-reveal">
											<img
												src="/images/Linda.jpg"
												alt="Linda Cartier"
												class="h-auto w-full object-cover"
												width="340"
												height="387"
												loading="lazy"
												decoding="async"
											/>
										</div>
									</div>

									<div class="max-w-none">
										<h2
											id="background-heading"
											class="page-title--section scroll-mt-32"
										>
											Professional Background
										</h2>
										<p class="about-body-copy page-body mt-4 max-w-none">
											As a strong advocate for
											<strong> higher standards in financial planning</strong>, she taught the
											CFP (Certified Financial Planner) Course at Cambrian College and financial
											education courses for the general public. Linda was the first financial
											planner in Northeastern Ontario to hold both the CFP (Certified Financial
											Planner) and R.F.P. (Registered Financial Planner) designations. She is
											also a PRP (Professional Retirement Planner) and an ELP (Enhanced
											Lifestyle Planner) and is a CFDS (Chartered Financial Divorce Specialist).
											She is the proprietor of the
											<strong> Academy of Financial Divorce Specialists</strong> that trains
											Canadian qualified financial professionals to help those dealing with
											financial matters in separation and divorce. The website is
											<strong> www.afds.ca</strong> for more information.
										</p>
										<p class="about-body-copy page-body mt-4 max-w-none">
											She has been involved in numerous volunteer activities and received
											awards for this work and continues to support local initiatives as do
											both Melanie and John.
										</p>
									</div>
								</div>
							</div>
						</section>

						<section id="recognition" class="my-10 sm:my-12 reveal">
							<div class="py-10 sm:py-11">
								<div class="about-recognition page-copy--wide">
									<h2
										id="recognition-heading"
										class="page-title--section scroll-mt-32"
									>
										Recognition and Client Feedback
									</h2>
									<div class="about-testimonial-stack mt-4 space-y-7 text-sm leading-7 text-[color:var(--ink-body)]">
										<p class="about-body-copy max-w-[41rem]">
											Linda received recognition as
											<strong>Favorite Financial Planner</strong>
											on three separate occasions in newspaper polls.
										</p>
										<div class="about-testimonial space-y-3 border-t border-[color:var(--accent-muted)]/70 pt-6">
											<p>
												<strong class="font-semibold text-[color:var(--ink-strong)]">
													Talbot Stevens
													<br />
													Financial Speaker, Educator and Author
												</strong>
											</p>
											<p class="max-w-[37rem] pl-4 text-base text-[color:var(--ink-muted)]">
												<em>
													"I am sincerely impressed with Linda Cartier's professionalism.
													Financial Planning is about identifying individual goals, detailing a
													plan to achieve these goals and following it through. Linda takes the
													time to get to know her clients and provide the most comprehensive
													financial plans I have ever seen."
												</em>
											</p>
										</div>
										<div class="about-testimonial space-y-3 border-t border-[color:var(--accent-muted)]/70 pt-7">
											<p>
												<strong class="font-semibold text-[color:var(--ink-strong)]">D.M Thomson R.N. B.A. B.ScN</strong>
											</p>
											<p class="max-w-[37rem] pl-4 text-base text-[color:var(--ink-muted)]">
												<em>
													"I have worked with Linda Cartier as my personal financial planner for
													over 25 years. I have referred others to Linda in the expectation they
													will enjoy the same financial achievement as myself. Linda has been
													prompt in returning all my phone calls and answering questions. She
													possesses extensive knowledge and the patience to assist people in
													coming to a full understanding of their financial situation and to
													assist them in constructive solutions."
												</em>
											</p>
										</div>
									</div>
								</div>
							</div>
						</section>
					</div>

					<div class="about-planning-band page-band page-band--soft relative left-1/2 w-[100dvw] -translate-x-1/2 py-10 sm:py-12 reveal">
						<div class="about-planning-grid page-container page-container--content">
							<section id="planning" class="about-planning-item">
								<div class="page-copy">
								<h2
									id="planning-heading"
									class="page-title--section scroll-mt-32"
								>
									Comprehensive Planning
								</h2>
								<p class="about-body-copy page-body mt-4 max-w-[40rem]">
									As our name implies, we help clients determine the best
									<strong> financial decisions </strong>
									based on their own and/or their families lifestyle goals and
									objectives. This is done through the development of a
									<strong> comprehensive financial plan </strong>
									which will consider all aspects including consideration of debt
									reduction and control through budgeting as well as saving and
									investing. Also protection through appropriate insurance if required.
									These <strong>plans are updated</strong> on a regular basis or as
									circumstances change.
								</p>
								</div>
							</section>

							<section id="life-stages" class="about-planning-item mt-8 border-t border-[color:var(--accent-muted)]/80 pt-8">
								<div class="page-copy">
								<h2
									id="life-stages-heading"
									class="page-title--section scroll-mt-32"
								>
									Planning Through Life's Stages
								</h2>
								<p class="about-body-copy page-body mt-4 max-w-[40rem]">
									<strong>The earlier you plan the better</strong> the results which
									include investing, as even small amounts grow to large over time. This
									is also the time to establish <strong>budgeting habits</strong> that
									endure over a lifetime. Marriage, starting a family and possibly home
									ownership, can mean setting and <strong>realizing goals</strong> through
									thoughtful financial planning. Considerations such as future education
									costs for children and putting aside money for other goals including
									eventual retirement. Besides short term savings for unexpected expenses
									and even vacations, investing longer term in
									<strong>
										Tax Free Savings Accounts and Registered Retirement plans
									</strong>
									can help. Not to be forgotten is protection through insurance.
									Entering into retirement requires careful evaluation of sources of
									income and lifestyle requirements as aging progresses. Later estate
									planning considerations become important. At Financial Decisions we
									have had <strong>years of dealing with clients</strong> at all stages of
									their life journey and enjoy helping with their lifestyle and financial
									matters so to the greatest extent possible they can realize their goals
									and dreams.
								</p>
								</div>
							</section>
						</div>
					</div>

					<section id="divorce-guidance" class="reveal">
						<div class="relative left-1/2 w-[100dvw] -translate-x-1/2 py-10 sm:py-12">
							<div class="page-container page-container--content">
								<div class="about-split about-split--divorce grid gap-8 md:grid-cols-[minmax(250px,0.82fr)_minmax(0,1.18fr)] md:items-center md:gap-11">
								<div class="w-full">
									<div class="about-media-frame about-media-frame--certificate mx-auto w-full max-w-[315px] overflow-hidden rounded-lg md:mx-0 img-reveal">
										<img
											src="/images/Chartered%20Financial%20Divorce%20Specialist.jpg"
											alt="Chartered Financial Divorce Specialist"
											class="h-full w-full object-cover"
											width="224"
											height="179"
											loading="lazy"
											decoding="async"
										/>
									</div>
								</div>

								<div class="page-copy">
									<h2
										id="divorce-guidance-heading"
										class="page-title--section scroll-mt-32"
									>
										Separation and Divorce Guidance
									</h2>
									<p class="about-body-copy page-body mt-4 max-w-[40rem]">
										It is unfortunate but many marriages end in separation and divorce.
										Linda Cartier is a Chartered Financial Divorce Specialist (CFDS) as
										well as her other professional designations, and has
										<strong> assisted many individuals and couples </strong>
										in dealing with the financial issues involved in this process. She
										acts as a neutral in these situations often working with life coaches,
										lawyers and mediators to achieve the most favourable outcomes for
										those involved. For more information please visit the website
										<a
											href="https://www.afds.ca"
											target="_blank"
											rel="noopener"
											class="font-semibold text-[color:var(--ink-heading)] hover:text-[color:var(--ink-body)]"
										>
											www.afds.ca
										</a>
										or call the office at 705-525-7526.
									</p>
								</div>
							</div>
							</div>
						</div>
					</section>

					<section id="office" class="border-t border-[color:var(--accent-muted)] reveal">
						<div class="pt-14 sm:pt-16">
							<div class="about-split about-split--office grid gap-8 md:grid-cols-[minmax(0,1fr)_minmax(300px,0.96fr)] md:items-start md:gap-11">
								<div class="page-copy">
									<h2
										id="office-heading"
										class="page-title--section scroll-mt-32"
									>
										Our Office
									</h2>
									<p class="about-body-copy page-body mt-4 max-w-[40rem]">
										Operating for several years in various locations as the only
										<strong> fully independent </strong>
										financial planning and investment firm in Northern Ontario we found a
										permanent home when we purchased the historic Barry Property on Bellevue
										Avenue shown below, located on an acre of land on the shores of Minnow
										Lake, which had just become available on the passing of
										<strong> Mrs. Barry, a pioneer resident of the area at age 89 in 2000.</strong>
										This property was zoned commercial so was ideal for our purpose although
										renovations were necessary to the home which was built in the 1930's. It
										was conveniently located close to our residence which made it even more
										attractive as we can walk to work. Our clients appreciate the
										<strong> warm and welcoming atmosphere </strong>
										of this fine old building.
									</p>
									<p class="about-body-copy page-body mt-4 max-w-[40rem]">
										The office is located at
										<a
											href="https://www.google.com/maps/search/?api=1&query=1546%20Bellevue%20Avenue%2C%20Sudbury%2C%20ON%2C%20P3B%203G2"
											target="_blank"
											rel="noopener"
											class="font-semibold"
										>
											1546 Bellevue Avenue
										</a>
										close to the corner of Bancroft Drive and Bellevue Avenue in Minnow Lake
										as shown on the map above. Watch for signs on the fence. Office hours are
										weekdays 9 to 5 with appointments after hours.
									</p>
								</div>

								<div class="w-full space-y-3 md:justify-self-end">
									<div class="about-media-frame about-media-frame--office overflow-hidden rounded-lg img-reveal">
										<img
											src="/images/Office%202.jpg"
											alt="Historic office exterior"
											class="h-full w-full object-cover"
											width="413"
											height="246"
											loading="lazy"
											decoding="async"
										/>
									</div>
									<a
										href="https://www.google.com/maps/search/?api=1&query=1546%20Bellevue%20Avenue%2C%20Sudbury%2C%20ON%2C%20P3B%203G2"
										target="_blank"
										rel="noopener"
										class="no-link-style block"
									>
										<div class="about-media-frame about-media-frame--map overflow-hidden rounded-lg img-reveal">
											<img
												src="/images/map.jpg"
												alt="Map showing the office location"
												class="h-full w-full object-cover"
												width="417"
												height="187"
												loading="lazy"
												decoding="async"
											/>
										</div>
									</a>
								</div>
							</div>
						</div>
					</section>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.about-page {
		background:
			linear-gradient(180deg, rgba(var(--surface-page-tint-rgb), 0.86) 0%, rgba(var(--white-rgb), 1) 28rem),
			var(--surface-page);
	}

	.about-intro-section {
		background: linear-gradient(
			180deg,
			rgba(var(--surface-band-rgb), 0.72) 0%,
			rgba(var(--white-rgb), 0.96) 56%,
			rgba(var(--white-rgb), 1) 100%
		);
		border-top: 1px solid rgba(var(--accent-rgb), 0.12);
	}

	#family-business {
		padding-top: 0.5rem;
	}

	.about-section--opening {
		padding-top: clamp(0.75rem, 2vw, 1.5rem);
	}

	.about-split {
		position: relative;
	}

	.about-split--office::before {
		content: '';
		position: absolute;
		inset: auto auto -1.75rem 0;
		width: min(9rem, 38vw);
		height: 1px;
		background: rgba(var(--accent-rgb), 0.26);
	}

	.about-media-frame {
		position: relative;
		border: 1px solid var(--rule-bronze);
		background: var(--surface-warm);
		box-shadow: 0 18px 38px rgba(var(--ink-shadow-rgb), 0.09);
	}

	.about-media-frame::after {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		border-radius: inherit;
		box-shadow: inset 0 0 0 1px rgba(var(--white-rgb), 0.34);
	}

	.about-media-frame img {
		display: block;
		transition: transform 700ms ease;
	}

	.about-media-frame--office img,
	.about-media-frame--map img {
		height: 100%;
	}

	.about-media-frame--portrait,
	.about-media-frame--certificate {
		box-shadow: 0 16px 34px rgba(var(--ink-shadow-rgb), 0.08);
	}

	.about-recognition {
		max-width: 48rem;
	}

	.about-testimonial-stack {
		position: relative;
	}

	.about-testimonial {
		border-color: var(--rule-bronze) !important;
	}

	.about-testimonial p:last-child {
		position: relative;
		padding-left: clamp(1.1rem, 2vw, 1.45rem);
		border-left: 2px solid rgba(var(--accent-rgb), 0.34);
	}

	.about-planning-band {
		border-top: 1px solid rgba(var(--accent-rgb), 0.12);
		border-bottom: 1px solid rgba(var(--accent-rgb), 0.1);
	}

	.about-planning-grid {
		display: grid;
		gap: clamp(1.75rem, 3vw, 2.5rem);
	}

	.about-planning-item {
		position: relative;
	}

	.about-split--office {
		padding-bottom: clamp(0.75rem, 1.8vw, 1.25rem);
	}

	.about-media-frame--office {
		aspect-ratio: 1.32;
	}

	.about-media-frame--map {
		aspect-ratio: 1.74;
		box-shadow: 0 12px 26px rgba(var(--ink-shadow-rgb), 0.07);
	}

	.about-body-copy {
		font-size: var(--text-body);
		line-height: 1.8;
		color: var(--ink-body);
		text-wrap: pretty;
	}

	.about-body-copy strong {
		color: var(--ink-stronger);
		font-weight: 650;
	}

	@media (min-width: 768px) {
		.about-split--portrait,
		.about-split--divorce {
			padding-block: clamp(0.25rem, 1vw, 0.75rem);
		}

		.about-planning-grid {
			grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
			align-items: start;
		}

		#life-stages.about-planning-item {
			margin-top: 0 !important;
			padding-top: 0 !important;
			padding-left: clamp(1.75rem, 3.4vw, 2.5rem);
			border-top: 0 !important;
			border-left: 1px solid rgba(var(--accent-rgb), 0.2);
		}
	}

	@media (max-width: 767px) {
		.about-media-frame {
			box-shadow: 0 12px 28px rgba(var(--ink-shadow-rgb), 0.08);
		}

		.about-split--office::before {
			display: none;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.about-media-frame img {
			transition: none;
		}
	}
</style>
