---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout>
	<main class="overflow-x-clip">
		<Hero
			title="About the Firm"
			subtitle="Independent, family-run financial planning rooted in Sudbury and Northern Ontario."
			className="bg-stone-50"
			contentClass="py-10 sm:py-12"
		/>

		<section class="no-divider bg-[color:var(--accent-soft)]/40 reveal" data-reveal-immediate>
			<div class="container mx-auto px-6 py-4 sm:py-5">
				<div class="max-w-3xl">
					<nav
						class="flex flex-wrap items-center gap-x-2 gap-y-1.5 text-sm text-slate-600"
						aria-label="About page sections"
					>
						<a
							href="#family-business-heading"
							class="text-sm text-slate-600 underline-offset-4 hover:text-slate-900 hover:underline focus:outline-none focus:ring-2 focus:ring-slate-300"
						>
							Family Business
						</a>
						<span class="mx-2 text-slate-300" aria-hidden="true">|</span>
						<a
							href="#background-heading"
							class="text-sm text-slate-600 underline-offset-4 hover:text-slate-900 hover:underline focus:outline-none focus:ring-2 focus:ring-slate-300"
						>
							Background
						</a>
						<span class="mx-2 text-slate-300" aria-hidden="true">|</span>
						<a
							href="#recognition-heading"
							class="text-sm text-slate-600 underline-offset-4 hover:text-slate-900 hover:underline focus:outline-none focus:ring-2 focus:ring-slate-300"
						>
							Recognition
						</a>
						<span class="mx-2 text-slate-300" aria-hidden="true">|</span>
						<a
							href="#planning-heading"
							class="text-sm text-slate-600 underline-offset-4 hover:text-slate-900 hover:underline focus:outline-none focus:ring-2 focus:ring-slate-300"
						>
							Planning
						</a>
						<span class="mx-2 text-slate-300" aria-hidden="true">|</span>
						<a
							href="#life-stages-heading"
							class="text-sm text-slate-600 underline-offset-4 hover:text-slate-900 hover:underline focus:outline-none focus:ring-2 focus:ring-slate-300"
						>
							Life Stages
						</a>
						<span class="mx-2 text-slate-300" aria-hidden="true">|</span>
						<a
							href="#divorce-guidance-heading"
							class="text-sm text-slate-600 underline-offset-4 hover:text-slate-900 hover:underline focus:outline-none focus:ring-2 focus:ring-slate-300"
						>
							Divorce Guidance
						</a>
						<span class="mx-2 text-slate-300" aria-hidden="true">|</span>
						<a
							href="#office-heading"
							class="text-sm text-slate-600 underline-offset-4 hover:text-slate-900 hover:underline focus:outline-none focus:ring-2 focus:ring-slate-300"
						>
							Our Office
						</a>
					</nav>
				</div>
			</div>
		</section>

		<section class="bg-white no-divider reveal" id="history" data-reveal-immediate>
			<div class="container mx-auto max-w-5xl px-6 py-8 sm:py-10">
				<div class="space-y-16 sm:space-y-20">
					<section id="family-business">
						<div class="py-1 sm:py-2">
							<div class="grid gap-9 md:grid-cols-[minmax(0,1fr)_minmax(340px,0.95fr)] md:items-center md:gap-12">
								<div class="max-w-[42rem]">
									<h2
										id="family-business-heading"
										class="scroll-mt-32 text-2xl font-semibold leading-tight tracking-tight text-slate-900"
									>
										A Family Business
									</h2>
									<div class="mt-4 max-w-[40rem] text-sm leading-7 text-slate-700">
										Financial Decisions is locally owned and operated by the husband and wife
										team of
										<strong> John Lindsay and Linda Cartier and daughter Melanie Cartier.</strong>
										The firm recently received a 25 year membership plaque in the Greater
										Sudbury Chamber of Commerce. Linda is President of the company since its
										formation and has had extensive experience in the financial services
										industry and as a community volunteer together with her partners.
									</div>
								</div>

								<div class="w-full md:justify-self-end">
									<div class="mx-auto w-full max-w-[440px] overflow-hidden rounded-lg md:mx-0">
										<img
											src="/images/Family.jpg"
											alt="Family business team"
											class="h-full w-full object-cover"
											loading="lazy"
											decoding="async"
										/>
									</div>
								</div>
							</div>
						</div>
					</section>

					<div>
						<section
							id="background"
							class="relative left-1/2 my-8 w-[100dvw] -translate-x-1/2 sm:my-10 bg-[color:var(--accent-soft)]/45 reveal"
						>
							<div class="container mx-auto max-w-5xl px-6 py-5 sm:py-7">
								<div class="grid gap-8 md:grid-cols-[270px_minmax(0,1fr)] md:items-center md:gap-10">
									<div class="w-full md:pt-1">
										<div class="mx-auto w-full max-w-[270px] overflow-hidden rounded-lg md:mx-0 img-reveal">
											<img
												src="/images/Linda.jpg"
												alt="Linda Cartier"
												class="h-auto w-full object-cover"
												loading="lazy"
												decoding="async"
											/>
										</div>
									</div>

									<div class="max-w-none">
										<h2
											id="background-heading"
											class="scroll-mt-32 text-2xl font-semibold leading-tight tracking-tight text-slate-900"
										>
											Professional Background
										</h2>
										<p class="mt-4 max-w-none text-sm leading-7 text-slate-700">
											As strong advocate for
											<strong> higher standards in financial planning</strong>, she taught the
											CFP (Certified Financial Planner) Course at Cambrian College and financial
											education courses for the general public. Linda was the first financial
											planner in Northeastern Ontario to hold both the CFP (Certified Financial
											Planner) and R.F.P. (Registered Financial Planner) designations. She is
											also a PRP (Professional Retirement Planner) and an ELP (Enhanced
											Lifestyle Planner) and is a CFDS (Chartered Financial Divorce Specialist).
											She is the proprietor of the
											<strong> Academy of Financial Divorce Specialists</strong> that trains
											Canadian qualified financial professionals to help those dealing with
											financial matters in separation and divorce. The website is
											<strong> www.afds.ca</strong> for more information.
										</p>
										<p class="mt-4 max-w-none text-sm leading-7 text-slate-700">
											She has been involved in numerous volunteer activities and received
											awards for this work and continues to support local initiatives as do
											both Melanie and John.
										</p>
									</div>
								</div>
							</div>
						</section>

						<section id="recognition" class="my-8 sm:my-10 reveal">
							<div class="py-8 sm:py-9">
								<div class="max-w-[44rem]">
									<h2
										id="recognition-heading"
										class="scroll-mt-32 text-2xl font-semibold leading-tight tracking-tight text-slate-900"
									>
										Recognition and Client Feedback
									</h2>
									<div class="mt-4 space-y-7 text-sm leading-7 text-slate-700">
										<p class="max-w-[41rem]">
											Linda received recognition as
											<strong>Favorite Financial Planner</strong>
											on three separate occasions in newspaper polls.
										</p>
										<div class="space-y-3 border-t border-[color:var(--accent-muted)]/70 pt-6">
											<p>
												<strong class="font-semibold text-slate-800">
													Talbot Stevens
													<br />
													Financial Speaker, Educator and Author
												</strong>
											</p>
											<p class="max-w-[37rem] pl-4 text-base text-slate-600">
												<em>
													"I am sincerely impressed with Linda Cartier's professionalism.
													Financial Planning is about identifying individual goals, detailing a
													plan to achieve these goals and following it through. Linda takes the
													time to get to know her clients and provide the most comprehensive
													financial plans I have ever seen."
												</em>
											</p>
										</div>
										<div class="space-y-3 border-t border-[color:var(--accent-muted)]/70 pt-7">
											<p>
												<strong class="font-semibold text-slate-800">D.M Thomson R.N. B.A. B.ScN</strong>
											</p>
											<p class="max-w-[37rem] pl-4 text-base text-slate-600">
												<em>
													"I have worked with Linda Cartier as my personal financial planner for
													over 25 years. I have referred others to Linda in the expectation they
													will enjoy the same financial achievement as myself. Linda has been
													prompt in returning all my phone calls and answering questions. She
													possesses extensive knowledge and the patience to assist people in
													coming to a full understanding of their financial situation and to
													assist them in constructive solutions."
												</em>
											</p>
										</div>
									</div>
								</div>
							</div>
						</section>
					</div>

					<div class="relative left-1/2 w-[100dvw] -translate-x-1/2 bg-[color:var(--accent-soft)]/45 py-8 sm:py-9 reveal">
						<div class="container mx-auto max-w-5xl px-6">
							<section id="planning">
								<div class="max-w-[42rem]">
								<h2
									id="planning-heading"
									class="scroll-mt-32 text-2xl font-semibold leading-tight tracking-tight text-slate-900"
								>
									Comprehensive Planning
								</h2>
								<p class="mt-4 max-w-[40rem] text-sm leading-7 text-slate-700">
									As our name implies, we help clients determine the best
									<strong> financial decisions </strong>
									based on their own and/or their families lifestyle goals and
									objectives. This is done though the development of a
									<strong> comprehensive financial plan </strong>
									which will consider all aspects including consideration of debt
									reduction and control through budgeting as well as saving and
									investing. Also protection through appropriate insurance if required.
									These <strong>plans are updated</strong> on a regular basis or as
									circumstances change.
								</p>
								</div>
							</section>

							<section id="life-stages" class="mt-6 border-t border-[color:var(--accent-muted)]/80 pt-6">
								<div class="max-w-[42rem]">
								<h2
									id="life-stages-heading"
									class="scroll-mt-32 text-2xl font-semibold leading-tight tracking-tight text-slate-900"
								>
									Planning Through Life's Stages
								</h2>
								<p class="mt-4 max-w-[40rem] text-sm leading-7 text-slate-700">
									<strong>The earlier you plan the better</strong> the results which
									include investing, as even small amounts grow to large over time. This
									is also the time to establish <strong>budgeting habits</strong> that
									endure over a lifetime. Marriage, starting a family and possibly home
									ownership, can mean setting and <strong>realizing goals</strong> through
									thoughtful financial planning. Considerations such as future education
									costs for children and putting aside money for other goals including
									eventual retirement. Besides short term savings for unexpected expenses
									and even vacations, investing longer term in
									<strong>
										Tax Free Savings Accounts and Registered Retirement plans
									</strong>
									can help. Not to be forgotten is protection through insurance.
									Entering into retirement requires careful evaluation of sources of
									income and lifestyle requirements as aging progresses. Later estate
									planning considerations become important. At Financial Decisions we
									have had <strong>years of dealing with clients</strong> at all stages of
									their life journey and enjoy helping with their lifestyle and financial
									matters so to the greatest extent possible they can realize their goals
									and dreams.
								</p>
								</div>
							</section>
						</div>
					</div>

					<section id="divorce-guidance" class="reveal">
						<div class="relative left-1/2 w-[100dvw] -translate-x-1/2 py-8 sm:py-9">
							<div class="container mx-auto max-w-5xl px-6">
								<div class="grid gap-8 md:grid-cols-[minmax(250px,0.82fr)_minmax(0,1.18fr)] md:items-center md:gap-11">
								<div class="w-full">
									<div class="mx-auto w-full max-w-[315px] overflow-hidden rounded-lg md:mx-0 img-reveal">
										<img
											src="/images/Chartered%20Financial%20Divorce%20Specialist.jpg"
											alt="Chartered Financial Divorce Specialist"
											class="h-full w-full object-cover"
											loading="lazy"
											decoding="async"
										/>
									</div>
								</div>

								<div class="max-w-[42rem]">
									<h2
										id="divorce-guidance-heading"
										class="scroll-mt-32 text-2xl font-semibold leading-tight tracking-tight text-slate-900"
									>
										Separation and Divorce Guidance
									</h2>
									<p class="mt-4 max-w-[40rem] text-sm leading-7 text-slate-700">
										It is unfortunate but many marriages end in separation and divorce.
										Linda Cartier is a Chartered Financial Divorce Specialist (CFDS) as
										well as her other professional designations, and has
										<strong> assisted many individuals and couples </strong>
										in dealing with the financial issues involved in this process. She
										acts as a neutral in these situations often working with life coaches,
										lawyers and mediators to achieve the most favourable outcomes for
										those involved. For more information please visit the website
										<a
											href="https://www.afds.ca"
											target="_blank"
											rel="noopener"
											class="font-semibold text-slate-900 hover:text-slate-700"
										>
											www.afds.ca
										</a>
										or call the office at 705-525-7526.
									</p>
								</div>
							</div>
							</div>
						</div>
					</section>

					<section id="office" class="border-t border-[color:var(--accent-muted)] reveal">
						<div class="pt-12 sm:pt-14">
							<div class="grid gap-8 md:grid-cols-[minmax(0,1fr)_minmax(300px,0.96fr)] md:items-start md:gap-11">
								<div class="max-w-[42rem]">
									<h2
										id="office-heading"
										class="scroll-mt-32 text-2xl font-semibold leading-tight tracking-tight text-slate-900"
									>
										Our Office
									</h2>
									<p class="mt-4 max-w-[40rem] text-sm leading-7 text-slate-700">
										Operating for several years in various locations as the only
										<strong> fully independent </strong>
										financial planning and investment firm in Northern Ontario we found a
										permanent home when we purchased the historic Barry Property on Bellevue
										Avenue shown below, located on an acre of land on the shores of Minnow
										Lake, which had just become available on the passing of
										<strong> Mrs. Barry, a pioneer resident of the area at age 89 in 2000.</strong>
										This property was zoned commercial so was ideal for our purpose although
										renovations were necessary to the home which was built in the 1930's. It
										was conveniently located close to our residence which made it even more
										attractive as we can walk to work. Our clients appreciate the
										<strong> warm and welcoming atmosphere </strong>
										of this fine old building.
									</p>
									<p class="mt-4 max-w-[40rem] text-sm leading-7 text-slate-700">
										The office is located at
										<a
											href="https://www.google.com/maps/search/?api=1&query=1546%20Bellevue%20Avenue%2C%20Sudbury%2C%20ON%2C%20P3B%203G2"
											target="_blank"
											rel="noopener"
											class="font-semibold"
										>
											1546 Bellevue Avenue
										</a>
										close to the corner of Bancroft Drive and Bellevue Avenue in Minnow Lake
										as shown on the map above. Watch for signs on the fence. Office hours are
										weekdays 9 to 5 with appointments after hours.
									</p>
								</div>

								<div class="w-full space-y-3 md:justify-self-end">
									<div class="overflow-hidden rounded-lg img-reveal">
										<img
											src="/images/Office%202.jpg"
											alt="Historic office exterior"
											class="h-full w-full object-cover"
											loading="lazy"
											decoding="async"
										/>
									</div>
									<a
										href="https://www.google.com/maps/search/?api=1&query=1546%20Bellevue%20Avenue%2C%20Sudbury%2C%20ON%2C%20P3B%203G2"
										target="_blank"
										rel="noopener"
										class="no-link-style block"
									>
										<div class="overflow-hidden rounded-lg img-reveal">
											<img
												src="/images/map.jpg"
												alt="Map showing the office location"
												class="h-full w-full object-cover"
												loading="lazy"
												decoding="async"
											/>
										</div>
									</a>
								</div>
							</div>
						</div>
					</section>
				</div>
			</div>
		</section>
	</main>
</Layout>
