---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');

const scorePost = (post) => {
	const fm = post.data ?? {};
	if (fm.date) return fm.date.valueOf();
	const issue = typeof fm.issue === 'string' ? fm.issue : '';
	const yearMatch = issue.match(/(19|20)\d{2}/);
	if (yearMatch) return new Date(`${yearMatch[0]}-12-31`).getTime();
	return 0;
};

const sorted = [...posts].sort((a, b) => scorePost(b) - scorePost(a));
const [latest, ...archive] = sorted;
---

<Layout>
	<main>
		<Hero
			title="Insights"
			subtitle="Seasonal newsletters and updates from the Financial Decisions team."
		/>

		<section class="bg-white">
			<div class="container mx-auto px-6 py-10 sm:py-12">
				{latest ? (
					<div class="rounded-lg border border-[color:var(--accent-muted)] bg-stone-50 p-6 sm:p-8">
						<p class="eyebrow text-[color:var(--accent)]">Latest Issue</p>
						<h2 class="mt-3 text-2xl font-semibold text-slate-900 sm:text-3xl">
							{latest.data?.title ?? 'Newsletter'}
						</h2>
						{latest.data?.issue && (
							<p class="mt-2 text-sm text-slate-600">
								{latest.data.issue}
							</p>
						)}
						<a
							href={latest.url}
							class="mt-5 inline-flex items-center text-sm font-semibold text-[color:var(--accent)] no-link-style hover:text-[color:var(--accent-dark)]"
						>
							Read the latest issue
						</a>
					</div>
				) : (
					<p class="text-sm text-slate-600">No newsletters are available yet.</p>
				)}

				{archive.length > 0 && (
					<div class="mt-10">
						<h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-600">
							Previous Issues
						</h3>
						<div class="mt-4 grid gap-4 sm:grid-cols-2">
							{archive.map((post) => (
								<a
									href={post.url}
									class="group rounded-lg border border-[color:var(--accent-muted)] bg-white p-5 transition hover:border-[color:var(--accent)]"
								>
									<p class="text-base font-semibold text-slate-900 group-hover:text-slate-900">
										{post.data?.title ?? 'Newsletter'}
									</p>
									{post.data?.issue && (
										<p class="mt-2 text-sm text-slate-600">
											{post.data.issue}
										</p>
									)}
								</a>
							))}
						</div>
					</div>
				)}
			</div>
		</section>
	</main>
</Layout>
