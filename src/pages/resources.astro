---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout>
	<main>
		<Hero
			title="Resources"
			subtitle="Market updates and video insight updates for clients."
		/>

		<section class="bg-stone-50" id="market">
			<div class="container mx-auto px-6 pt-10 pb-12 sm:pt-12 sm:pb-16">
				<div class="p-6 sm:p-8">
					<h2 class="text-2xl font-semibold text-slate-900">Market Information</h2>
					<p class="mt-2 text-sm text-slate-600">
						Selected third-party market reports, provided for your convenience.
					</p>
					<div class="mt-3 grid gap-6 lg:grid-cols-2">
						<div class="rounded-lg border border-[color:rgba(148,163,184,0.35)] bg-white p-6">
							<h3 class="text-xl font-semibold text-slate-900">
								Bloomberg Market Report
							</h3>
							<p class="mt-2 text-sm text-slate-600">
								Top headlines and daily market coverage.
							</p>
							<div class="mt-3">
								<a
									href="http://www.bnnbloomberg.ca"
									class="inline-flex items-center gap-2 text-sm font-semibold text-slate-900 hover:text-slate-700 hover:underline"
								>
									Latest Canadian and International Market News - BNN Bloomberg
									<span aria-hidden="true">-&gt;</span>
								</a>
							</div>
						</div>
						<div class="rounded-lg border border-[color:rgba(148,163,184,0.35)] bg-white p-6">
							<h3 class="text-xl font-semibold text-slate-900">Featured Report</h3>
							<p class="mt-2 text-sm text-slate-600">
								Latest portfolio managers brief from Croft Financial Group.
							</p>
							<a
								href="https://croftgroup.com/portfolio-managers-brief/portfolio-managers-brief-september-2025/"
								class="mt-3 block text-sm font-semibold text-slate-900 hover:text-slate-700 hover:underline"
							>
								Portfolio Managers Brief for September 2025
							</a>
						</div>
					</div>
					<div class="mt-8 rounded-lg border border-[color:rgba(148,163,184,0.35)] bg-white p-6">
						<h3 class="text-xl font-semibold text-slate-900">Croft Portfolio Reports</h3>
						<p class="mt-2 text-sm text-slate-600">
							Featured in chronological order are Portfolio Managers Briefs and
							Reports and Research by Richard Croft, founder of the Croft Financial
							Group who has been in the industry since 1975. He has written nine books
							and thousands of articles and commentaries for Canada's largest print and
							electronic media channels. He is actively involved in the Croft
							organization.
						</p>
						<ul class="mt-4 divide-y divide-slate-200 text-sm text-slate-700">
							<li>
								<a
									href="https://croftgroup.com/podcast/pilot-money-talks-we-listen/"
									class="block py-3 font-semibold text-slate-900 hover:text-slate-700 hover:underline"
								>
									Money Talks - We Listen - Podcast
								</a>
							</li>
							<li>
								<a
									href="https://croftgroup.com/portfolio-managers-brief/portfolio-managers-brief-july-2025/"
									class="block py-3 font-semibold text-slate-900 hover:text-slate-700 hover:underline"
								>
									Portfolio Managers Brief for July 2025
								</a>
							</li>
							<li>
								<a
									href="/Research%20Report%20July%202025_The%20Epstein%20Deflection%20(002).pdf"
									class="block py-3 font-semibold text-slate-900 hover:text-slate-700 hover:underline"
								>
									Richard Croft - Economic Research Report - The Epstein Deflection July
									2025
								</a>
							</li>
							<li>
								<a
									href="https://croftgroup.com/portfolio-managers-brief/portfolio-managers-brief-june-2025/"
									class="block py-3 font-semibold text-slate-900 hover:text-slate-700 hover:underline"
								>
									Portfolio Managers Brief for June 2025
								</a>
							</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<section class="bg-white no-divider" id="video-updates">
			<div class="container mx-auto px-6 py-10 sm:py-12">
				<div class="p-6 sm:p-8">
					<h2 class="text-2xl font-semibold text-slate-900">Video Updates</h2>
					<p class="mt-2 text-sm text-slate-600">
						Recent video updates with planning ideas and market commentary.
					</p>
					<div class="mt-6">
						<div class="rounded-lg border border-[color:rgba(148,163,184,0.35)] bg-white p-6">
							<p class="mt-4 text-sm font-semibold uppercase tracking-[0.15em] text-slate-500">
								Most Recent
							</p>
							<a
								class="mt-1 inline-flex text-lg font-semibold text-slate-900 hover:text-slate-700 hover:underline"
								href="https://youtu.be/hbwP2wbbWng"
								target="_blank"
								rel="noopener"
							>
								Spring 2025 Video Update
							</a>
							<div class="mx-auto mt-4 w-full max-w-md overflow-hidden rounded-md border border-slate-200">
								<div class="relative w-full pt-[56.25%]">
									<iframe
										class="absolute left-0 top-0 h-full w-full"
										src="https://www.youtube.com/embed/hbwP2wbbWng"
										title="Spring 2025 Video Update"
										allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
										referrerpolicy="strict-origin-when-cross-origin"
										allowfullscreen
									></iframe>
								</div>
							</div>
							<p class="mt-6 text-sm font-semibold uppercase tracking-[0.15em] text-slate-500">
								Archived
							</p>
							<div class="mt-3 overflow-x-auto">
								<table class="w-full text-left text-sm text-slate-700">
									<thead class="border-b border-slate-200 text-xs uppercase tracking-wide text-slate-500">
										<tr>
											<th class="py-2">Title</th>
											<th class="py-2">Year</th>
										</tr>
									</thead>
									<tbody>
										<tr class="border-b border-slate-100">
											<td class="py-3">
												<a
													class="font-semibold text-slate-900 hover:text-slate-700 hover:underline"
													href="https://youtu.be/5kNPp5YPRnw"
													target="_blank"
													rel="noopener"
												>
													Winter 2025 Video Update
												</a>
											</td>
											<td class="py-3">2025</td>
										</tr>
									</tbody>
								</table>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
