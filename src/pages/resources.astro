---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

const videos = [
	{
		title: 'Winter 2026 Video Update',
		url: 'https://www.youtube.com/watch?v=Vys0H5ZUCrw',
		embedUrl: 'https://www.youtube.com/embed/Vys0H5ZUCrw',
		videoId: 'Vys0H5ZUCrw',
		year: '2026',
		description:
			'In this winter update, the Financial Decisions team reflects on the year in financial markets, noting strong portfolio performance despite global uncertainty and rising costs. They discuss the importance of aligning investments with personal goals, highlight planning tools such as the First Home Savings Account and Tax-Free Savings Account, and encourage clients to stay focused on long-term financial planning as they look ahead to the coming year.',
		length: '~9 minutes',
	},
	{
		title: 'Spring 2025 Video Update',
		url: 'https://youtu.be/hbwP2wbbWng',
		embedUrl: 'https://www.youtube.com/embed/hbwP2wbbWng',
		videoId: 'hbwP2wbbWng',
		year: '2025',
		description:
			'In this video, the Financial Decisions team discusses recent global market volatility, geopolitical developments, and tariff tensions affecting investor sentiment. They emphasize the importance of diversification, long-term financial planning, and maintaining a disciplined investment strategy during uncertain market conditions.',
		length: '~16 minutes',
	},
	{
		title: 'Winter 2025 Video Update',
		url: 'https://youtu.be/5kNPp5YPRnw',
		embedUrl: 'https://www.youtube.com/embed/5kNPp5YPRnw',
		videoId: '5kNPp5YPRnw',
		year: '2025',
		description:
			'In this winter update, the Financial Decisions team discusses recent market performance, the potential for volatility in the year ahead, and how portfolio managers are protecting gains while preparing for future opportunities. They also review tax planning considerations, charitable donation deadlines, and practical tips to help clients stay focused on long-term financial goals.',
		length: '~13 minutes',
	},
];

const partnerResearch = [
	{
		title: 'Portfolio Managers Brief for February 2026',
		description: 'Monthly commentary on market conditions and portfolio strategy.',
		href: 'https://croftgroup.com/portfolio-managers-brief/portfolio-managers-brief-february-2026/',
	},
	{
		title: 'The Case for Gold - Podcast',
		description: 'Perspective on gold markets and portfolio diversification considerations (January 26, 2026).',
		href: 'https://croftgroup.com/podcast/the-case-for-gold/',
	},
	{
		title: 'January 2026 Research Report - The Golden Age',
		description: 'Economic research commentary from January 2026.',
		href: '/insights-assets/newsletters/January%202026%20Research%20Report%20-%20The%20Golden%20Age.pdf',
	},
	{
		title: "What's Next for Canadian Financials? - Podcast",
		description: 'Discussion of current themes influencing Canadian financial sector outlook.',
		href: 'https://croftgroup.com/podcast/whats-next-for-canadian-financials/',
	},
	{
		title: 'The State of Canadian Energy - Money Talks - We Listen - Podcast',
		description: 'Discussion of current trends in Canadian energy markets and implications.',
		href: 'https://croftgroup.com/podcast/the-state-of-canadian-energy-money-talks-we-listen/',
	},
	{
		title: 'AI Bubble - Macro Economic Research Report',
		description: 'Macro economic perspective on AI-related market valuation risks.',
		href: 'https://croftgroup.com/macro-economic-research-report/ai-bubble/',
	},
];

const trustedLinks = [
	{
		title: 'Bloomberg Market Report',
		description: 'Top headlines and daily market coverage.',
		href: 'http://www.bnnbloomberg.ca',
		linkLabel: 'Latest Canadian and International Market News - BNN Bloomberg',
	},
];

const [featured, ...others] = videos;
const videoCountLabel = `${videos.length} videos`;
const partnerResearchCountLabel = `${partnerResearch.length} reports`;
const trustedLinksCountLabel = `${trustedLinks.length} ${trustedLinks.length === 1 ? 'link' : 'links'}`;
---

<Layout
	title="Resources | Financial Decisions"
	description="Video updates, partner research, and trusted market links from Financial Decisions."
>
	<main class="resources-page page-shell">
		<section class="video-updates-section page-section-soft no-divider reveal" id="video-updates">
			<div class="page-container page-container--content page-section--tight-top">
				<div class="video-updates-shell">
					<Hero
						variant="page"
						eyebrow="Resources"
						title="Video Updates"
						subtitle="Recent video updates discussing markets, financial planning, and investment topics."
					>
						<p class="resources-page-header__count">{videoCountLabel}</p>
					</Hero>
					<div class="resources-section resources-video-list">
						<article class="video-resource-card resources-feature-card">
							<div class="video-resource-card__copy">
								<div class="flex items-center justify-between gap-4">
									<p class="inner-page-eyebrow">Featured</p>
									<p class="text-xs font-medium text-[color:var(--ink-muted)]">{featured.year}</p>
								</div>
								<div class="mt-2 space-y-1">
									<h3 class="inner-page-item-title">{featured.title}</h3>
								</div>
								<p class="inner-page-body mt-2">{featured.description}</p>
								<p class="mt-2 text-xs font-medium uppercase tracking-wide text-[color:var(--ink-muted)]">
									Length: {featured.length}
								</p>
							</div>
							<div class="video-preview-shell resources-featured-video-preview mt-4 mx-auto w-full overflow-hidden rounded-lg border border-[color:var(--accent-muted)]">
								<div class="relative aspect-video bg-slate-100" data-video-frame>
									<button
										type="button"
										class="resources-video-trigger group absolute inset-0"
										aria-label={`Play ${featured.title}`}
										data-video-embed={featured.embedUrl}
										data-video-title={featured.title}
									>
										<img
											class="h-full w-full object-cover"
											src={`https://i.ytimg.com/vi/${featured.videoId}/hqdefault.jpg`}
											alt=""
											width="480"
											height="360"
											loading="lazy"
										/>
										<span class="resources-video-overlay absolute inset-0"></span>
										<span class="resources-video-play-indicator" aria-hidden="true">
											<span class="resources-video-play-indicator__button">
												<svg viewBox="0 0 20 20" aria-hidden="true">
													<path d="M6 4.75v10.5L14.75 10 6 4.75Z"></path>
												</svg>
											</span>
										</span>
									</button>
								</div>
							</div>
						</article>

						<div class="video-resources-grid">
							{others.map((video) => (
								<article class="video-resource-card">
									<div class="video-resource-card__copy">
										<div class="flex items-center justify-between gap-4">
											<p class="inner-page-eyebrow">
												Video Update
											</p>
											<p class="text-xs font-medium text-[color:var(--ink-muted)]">{video.year}</p>
										</div>
										<div class="mt-2 space-y-1">
											<h3 class="inner-page-item-title">{video.title}</h3>
										</div>
										<p class="inner-page-body mt-2">{video.description}</p>
										<p class="mt-2 text-xs font-medium uppercase tracking-wide text-[color:var(--ink-muted)]">
											Length: {video.length}
										</p>
									</div>
									<div class="video-preview-shell mt-4 overflow-hidden rounded-lg border border-[color:var(--accent-muted)]">
										<div class="relative aspect-video bg-slate-100" data-video-frame>
											<button
												type="button"
												class="resources-video-trigger group absolute inset-0"
												aria-label={`Play ${video.title}`}
												data-video-embed={video.embedUrl}
												data-video-title={video.title}
											>
												<img
													class:list={[
														'h-full w-full object-cover',
														video.videoId === 'hbwP2wbbWng' && 'resources-video-thumb--summer-2025',
													]}
													src={`https://i.ytimg.com/vi/${video.videoId}/hqdefault.jpg`}
													alt=""
													width="480"
													height="360"
													loading="lazy"
												/>
												<span class="resources-video-overlay absolute inset-0"></span>
												<span class="resources-video-play-indicator" aria-hidden="true">
													<span class="resources-video-play-indicator__button">
														<svg viewBox="0 0 20 20" aria-hidden="true">
															<path d="M6 4.75v10.5L14.75 10 6 4.75Z"></path>
														</svg>
													</span>
												</span>
											</button>
										</div>
									</div>
								</article>
							))}
						</div>
					</div>
				</div>
			</div>
			<script is:inline>
				(() => {
					const section = document.querySelector('#video-updates');
					if (!section) return;

					const setup = () => {
						const triggers = section.querySelectorAll('button[data-video-embed]');
						triggers.forEach((trigger) => {
							trigger.addEventListener(
								'click',
								() => {
									const frame = trigger.closest('[data-video-frame]');
									const embedUrl = trigger.getAttribute('data-video-embed');
									const title = trigger.getAttribute('data-video-title');
									if (!frame || !embedUrl || !title) return;

									const iframe = document.createElement('iframe');
									iframe.className = 'absolute left-0 top-0 h-full w-full';
									iframe.src = `${embedUrl}?autoplay=1`;
									iframe.title = title;
									iframe.allow =
										'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
									iframe.referrerPolicy = 'strict-origin-when-cross-origin';
									iframe.setAttribute('allowfullscreen', '');
									frame.replaceChildren(iframe);
								},
								{ once: true }
							);
						});
					};

					if (document.readyState === 'loading') {
						document.addEventListener('DOMContentLoaded', setup, { once: true });
					} else {
						setup();
					}
				})();
			</script>
		</section>

		<section class="resources-link-section no-divider reveal" id="partner-research">
			<div class="page-container page-container--content page-section--compact">
				<div class="resources-link-panel">
					<div class="resources-section-header page-stack">
						<div class="resources-section-header__top">
							<h2 id="partner-research-heading" class="page-title--section scroll-mt-40">Partner Research</h2>
							<span class="resources-section-header__count">{partnerResearchCountLabel}</span>
						</div>
						<p class="page-subtext">
							Market insights and commentary from Croft Financial Group, our investment research partner.
						</p>
					</div>
					<div class="resources-section resources-link-list resources-link-list--partner">
						{partnerResearch.map((item) => (
							<a
								href={item.href}
								class="partner-research-card group no-underline hover:no-underline focus-visible:no-underline"
								target="_blank"
								rel="noopener"
							>
								<div class="partner-research-card__content">
									<div class="partner-research-card__header">
										<div class="partner-research-card__eyebrow">
											Market Commentary &middot; Croft Financial Group
										</div>
										<h3 class="inner-page-item-title">{item.title}</h3>
									</div>
									<p class="inner-page-body partner-research-card__copy">{item.description}</p>
									<div class="partner-research-card__footer">
										<span class="partner-research-card__action">Open research</span>
										<span class="partner-research-card__indicator" aria-hidden="true">
											<svg
												class="partner-research-card__indicator-arrow h-4 w-4"
												viewBox="0 0 20 20"
												fill="none"
												stroke="currentColor"
												stroke-width="1.8"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<path d="M6 14 14 6" />
												<path d="M7 6h7v7" />
											</svg>
										</span>
									</div>
								</div>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="resources-link-section resources-link-section--last mt-0 no-divider reveal" id="trusted-links">
			<div class="page-container page-container--content page-section--compact">
				<div class="resources-link-panel resources-link-panel--plain">
					<div class="resources-section-header page-stack">
						<div class="resources-section-header__top">
							<h2 id="trusted-links-heading" class="page-title--section scroll-mt-40">Trusted Links</h2>
							<span class="resources-section-header__count">{trustedLinksCountLabel}</span>
						</div>
						<p class="page-subtext">External sources and market commentary.</p>
					</div>
					<div class="resources-section resources-link-list resources-link-list--trusted">
						{trustedLinks.map((item) => (
							<a
								href={item.href}
								class="trusted-link-card partner-research-card group no-underline hover:no-underline focus-visible:no-underline"
								target="_blank"
								rel="noopener"
							>
								<div class="partner-research-card__content">
									<div class="partner-research-card__header">
										<div class="partner-research-card__eyebrow">Market News</div>
										<h3 class="inner-page-item-title">{item.title}</h3>
									</div>
									<p class="inner-page-body partner-research-card__copy">{item.description}</p>
									<p class="partner-research-card__meta">{item.linkLabel}</p>
									<div class="partner-research-card__footer">
										<span class="partner-research-card__action">Visit source</span>
										<span class="partner-research-card__indicator" aria-hidden="true">
											<svg
												class="partner-research-card__indicator-arrow h-4 w-4"
												viewBox="0 0 20 20"
												fill="none"
												stroke="currentColor"
												stroke-width="1.8"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<path d="M6 14 14 6" />
												<path d="M7 6h7v7" />
											</svg>
										</span>
									</div>
								</div>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.resources-page {
		background:
			linear-gradient(180deg, rgba(var(--surface-page-tint-rgb), 0.88) 0%, rgba(var(--white-rgb), 1) 32rem),
			var(--surface-page);
	}

	.video-updates-section {
		background: transparent;
	}

	.video-updates-shell {
		padding-inline: 0 !important;
	}

	.resources-section-header {
		position: relative;
		padding-bottom: 1rem;
		border-bottom: 1px solid rgba(var(--accent-rgb), 0.16);
	}

	.resources-section-header__top {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.75rem 1rem;
	}

	.resources-section-header .page-title,
	.resources-section-header .page-title--section {
		max-width: 15ch;
	}

	.resources-section-header__count {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2rem;
		padding: 0.35rem 0.8rem;
		border: 1px solid rgba(var(--accent-rgb), 0.14);
		border-radius: var(--radius-full);
		background: rgba(var(--surface-band-rgb), 0.42);
		color: var(--ink-muted);
		font-size: 0.8rem;
		font-weight: 600;
		line-height: 1.2;
		letter-spacing: 0.02em;
	}

	.resources-page-header__count {
		font-size: var(--text-small);
		color: var(--ink-muted);
	}

	.resources-video-list {
		margin-top: var(--space-8);
		border-top: 1px solid rgba(var(--accent-rgb), 0.16);
	}

	.video-resource-card {
		padding-block: clamp(1.35rem, 3vw, 2rem);
		border-bottom: 1px solid rgba(var(--accent-rgb), 0.12);
	}

	.video-resource-card__copy {
		min-width: 0;
	}

	.resources-feature-card {
		padding-top: clamp(1.5rem, 3.2vw, 2.2rem);
	}

	.resources-featured-video-preview,
	.video-preview-shell {
		background: var(--surface-warm);
		box-shadow: 0 10px 24px rgba(var(--ink-shadow-rgb), 0.045);
	}

	.resources-featured-video-preview {
		max-width: 100%;
		box-shadow: 0 12px 28px rgba(var(--ink-shadow-rgb), 0.06);
	}

	.video-preview-shell iframe,
	.video-preview-shell img {
		display: block;
	}

	.resources-link-section {
		background: var(--surface-page);
	}

	.resources-link-panel {
		border-top: 1px solid rgba(var(--accent-rgb), 0.18);
		padding-top: clamp(1.15rem, 2.2vw, 1.55rem);
	}

	.resources-link-panel--plain {
		border-top-color: rgba(var(--accent-rgb), 0.14);
	}

	.resources-link-list {
		display: grid;
		gap: 0.9rem;
		margin-top: 1.15rem;
		border-top: 0;
		padding-top: 0;
	}

	.resources-link-list--partner {
		grid-template-columns: minmax(0, 1fr);
	}

	.resources-link-list--trusted {
		grid-template-columns: minmax(0, 1fr);
		max-width: 34rem;
	}

	.partner-research-card,
	.trusted-link-card {
		position: relative;
		display: block;
		padding: clamp(1rem, 1.8vw, 1.2rem);
		border: 1px solid rgba(var(--accent-rgb), 0.14);
		border-radius: 1rem;
		background: linear-gradient(
			180deg,
			rgba(var(--white-rgb), 0.96) 0%,
			rgba(var(--surface-warm-rgb), 0.8) 100%
		);
		box-shadow: 0 14px 30px rgba(var(--ink-shadow-rgb), 0.045);
		color: inherit;
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease,
			background-color 180ms ease;
	}

	.partner-research-card::before {
		content: none;
	}

	.partner-research-card:hover {
		transform: translateY(-2px);
		box-shadow: 0 18px 34px rgba(var(--ink-shadow-rgb), 0.06);
		border-color: rgba(var(--accent-rgb), 0.2);
	}

	.partner-research-card:active {
		color: inherit;
		transform: translateY(-1px);
	}

	.partner-research-card:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}

	.partner-research-card__content {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 0.7rem;
		align-items: start;
		height: 100%;
	}

	.partner-research-card__header {
		display: grid;
		gap: 0.32rem;
	}

	.partner-research-card__eyebrow,
	.partner-research-card__meta {
		color: var(--ink-muted);
	}

	.partner-research-card__eyebrow {
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.partner-research-card__copy {
		margin-top: 0;
		line-height: 1.7;
	}

	.partner-research-card__meta {
		margin: 0.1rem 0 0;
		font-size: 0.78rem;
		line-height: 1.55;
	}

	.partner-research-card__footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.8rem;
		margin-top: 0.2rem;
		padding-top: 0.85rem;
		border-top: 1px solid rgba(var(--accent-rgb), 0.1);
	}

	.partner-research-card__action {
		font-size: 0.84rem;
		font-weight: 600;
		line-height: 1.35;
		color: var(--accent);
	}

	.partner-research-card__indicator {
		display: inline-flex;
		height: 2rem;
		width: 2rem;
		align-items: center;
		justify-content: center;
		color: var(--accent);
		border: 1px solid rgba(var(--accent-rgb), 0.14);
		border-radius: var(--radius-full);
		background: rgba(var(--white-rgb), 0.78);
	}

	.partner-research-card__indicator-arrow {
		transition: transform 180ms ease;
	}

	.partner-research-card:hover .partner-research-card__indicator-arrow {
		transform: translateX(2px) translateY(-1px);
	}

	.resources-video-thumb--summer-2025 {
		object-position: center 28%;
	}

	.resources-video-trigger {
		overflow: hidden;
	}

	.resources-video-trigger img {
		transition: transform 620ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.resources-video-trigger:hover img {
		transform: scale(1.025);
	}

	.resources-video-overlay {
		background: linear-gradient(
			180deg,
			rgba(var(--ink-shadow-rgb), 0.14) 0%,
			rgba(var(--ink-shadow-rgb), 0.3) 100%
		);
		transition: background-color 180ms ease, opacity 180ms ease;
	}

	.resources-video-play-indicator {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		pointer-events: none;
	}

	.resources-video-play-indicator__button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: clamp(3.9rem, 9vw, 4.65rem);
		height: clamp(3.9rem, 9vw, 4.65rem);
		border: 1px solid rgba(var(--white-rgb), 0.74);
		border-radius: var(--radius-full);
		background: rgba(var(--white-rgb), 0.92);
		box-shadow:
			0 16px 30px rgba(var(--ink-shadow-rgb), 0.2),
			inset 0 1px 0 rgba(var(--white-rgb), 0.82);
		backdrop-filter: blur(4px);
		transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease;
	}

	.resources-video-play-indicator__button svg {
		width: 1.75rem;
		height: 1.75rem;
		margin-left: 0.14rem;
		fill: var(--accent);
	}

	.resources-video-trigger:hover .resources-video-overlay {
		background: linear-gradient(
			180deg,
			rgba(var(--ink-shadow-rgb), 0.2) 0%,
			rgba(var(--ink-shadow-rgb), 0.36) 100%
		);
	}

	.resources-video-trigger:hover .resources-video-play-indicator__button {
		transform: scale(1.03);
		box-shadow:
			0 18px 34px rgba(var(--ink-shadow-rgb), 0.24),
			inset 0 1px 0 rgba(var(--white-rgb), 0.88);
	}

	.video-resource-card:hover {
		transform: none;
	}

	.resources-feature-card .inner-page-body {
		line-height: 1.88;
	}

	@media (min-width: 768px) {
		.resources-feature-card {
			display: grid;
			grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.92fr);
			gap: clamp(1.25rem, 3vw, 2rem);
			align-items: center;
