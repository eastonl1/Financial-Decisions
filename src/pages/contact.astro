---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout>
	<main>
		<Hero
			title="Contact Us"
			subtitle="We are here to help. Reach out with questions or to schedule a meeting."
			className="border-b border-slate-200"
		/>

		<section class="bg-white reveal no-divider">
			<div class="container mx-auto max-w-5xl px-6 py-5 sm:py-6 lg:py-8">
				<div class="grid gap-4 md:grid-cols-3 lg:gap-5">
					<a
						href="https://www.google.com/maps/search/?api=1&query=1546%20Bellevue%20Avenue%2C%20Sudbury%2C%20ON%2C%20P3B%203G2"
						target="_blank"
						rel="noopener"
						class="group flex h-full flex-col justify-between rounded-xl border border-[color:var(--accent-muted)] bg-stone-50 p-5 text-left text-slate-900 no-underline hover:border-[color:var(--accent)] hover:bg-white hover:no-underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[color:var(--accent-dark)] focus-visible:no-underline sm:p-6"
					>
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-700">
									Visit Us
								</p>
								<p class="mt-3 text-lg font-semibold leading-snug text-slate-900 sm:text-xl">
									1546 Bellevue Avenue
								</p>
								<p class="mt-1 text-base leading-relaxed text-slate-700">
									Sudbury, ON, P3B 3G2
								</p>
							</div>
							<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[color:var(--accent-muted)] bg-white text-[color:var(--accent)]" aria-hidden="true">
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 21s7-4.35 7-11a7 7 0 1 0-14 0c0 6.65 7 11 7 11Z" />
									<circle cx="12" cy="10" r="2.5" />
								</svg>
							</span>
						</div>
						<span class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-[color:var(--accent)]">
							Open in Maps
							<svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M6 14 14 6" />
								<path d="M7 6h7v7" />
							</svg>
						</span>
					</a>
					<a
						href="tel:7055257526"
						class="group flex h-full flex-col justify-between rounded-xl border border-[color:var(--accent-muted)] bg-stone-50 p-5 text-left text-slate-900 no-underline hover:border-[color:var(--accent)] hover:bg-white hover:no-underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[color:var(--accent-dark)] focus-visible:no-underline sm:p-6"
					>
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-700">
									Call Us
								</p>
								<p class="mt-3 text-lg font-semibold leading-snug text-slate-900 sm:text-xl">
									705-525-PLAN (7526)
								</p>
							</div>
							<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[color:var(--accent-muted)] bg-white text-[color:var(--accent)]" aria-hidden="true">
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.46 19.46 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.91.33 1.8.63 2.65a2 2 0 0 1-.45 2.11L8 9.91a16 16 0 0 0 6.09 6.09l1.43-1.29a2 2 0 0 1 2.11-.45c.85.3 1.74.51 2.65.63A2 2 0 0 1 22 16.92Z" />
								</svg>
							</span>
						</div>
						<span class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-[color:var(--accent)]">
							Tap to Call
							<svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M5 10h10" />
								<path d="m11 6 4 4-4 4" />
							</svg>
						</span>
					</a>
					<a
						href="mailto:fdi@financialdecisions.ca"
						class="group flex h-full flex-col justify-between rounded-xl border border-[color:var(--accent-muted)] bg-stone-50 p-5 text-left text-slate-900 no-underline hover:border-[color:var(--accent)] hover:bg-white hover:no-underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[color:var(--accent-dark)] focus-visible:no-underline sm:p-6"
					>
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-700">
									Email Us
								</p>
								<p class="mt-3 break-all text-lg font-semibold leading-snug text-slate-900 sm:break-normal sm:text-xl">
									fdi@financialdecisions.ca
								</p>
							</div>
							<span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-[color:var(--accent-muted)] bg-white text-[color:var(--accent)]" aria-hidden="true">
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" />
									<path d="m22 7-10 7L2 7" />
								</svg>
							</span>
						</div>
						<span class="mt-5 inline-flex items-center gap-2 text-sm font-medium text-[color:var(--accent)]">
							Send an Email
							<svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M5 10h10" />
								<path d="m11 6 4 4-4 4" />
							</svg>
						</span>
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>
