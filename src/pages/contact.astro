---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

const mapsUrl =
	'https://www.google.com/maps/search/?api=1&query=1546%20Bellevue%20Avenue%2C%20Sudbury%2C%20ON%2C%20P3B%203G2';
const mapsEmbedUrl =
	'https://www.google.com/maps?q=1546%20Bellevue%20Avenue%2C%20Sudbury%2C%20ON%2C%20P3B%203G2&z=15&output=embed';
---

<Layout
	title="Contact Financial Decisions | Sudbury Financial Planning Office"
	description="Contact Financial Decisions in Sudbury, Ontario, by phone, email, or by visiting our Bellevue Avenue office."
>
	<main class="contact-page page-shell">
		<section class="contact-methods-section page-section-soft reveal no-divider">
			<div class="page-container page-container--content page-section--tight-top">
				<Hero
					variant="page"
					eyebrow="Contact Us"
					title="Get in Touch"
					subtitle="Visit our Sudbury office, call during business hours, or email us directly."
				/>

				<div class="contact-methods-grid" aria-label="Financial Decisions contact details">
					<article class="contact-detail-card ui-card">
						<div class="contact-detail-card__header">
							<div class="contact-detail-card__heading">
								<p class="contact-detail-card__label">
									Visit Us
								</p>
								<div class="contact-detail-card__value" aria-label="Address">
									<p>1546 Bellevue Avenue</p>
									<p class="contact-detail-card__meta">Sudbury, ON, P3B 3G2</p>
								</div>
							</div>
							<span class="contact-detail-card__icon icon-circle" aria-hidden="true">
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 21s7-4.35 7-11a7 7 0 1 0-14 0c0 6.65 7 11 7 11Z" />
									<circle cx="12" cy="10" r="2.5" />
								</svg>
							</span>
						</div>
						<div class="contact-detail-card__actions">
							<button
								type="button"
								class="contact-copy-button"
								aria-label="Copy address"
								data-copy-value="1546 Bellevue Avenue, Sudbury, ON, P3B 3G2"
								data-copy-label="Address"
							>
								Copy
							</button>
							<a href={mapsUrl} target="_blank" rel="noopener" class="contact-detail-card__link">
								Open in Maps
								<svg class="contact-detail-card__action-arrow h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M6 14 14 6" />
									<path d="M7 6h7v7" />
								</svg>
							</a>
						</div>
					</article>

					<article class="contact-detail-card ui-card">
						<div class="contact-detail-card__header">
							<div class="contact-detail-card__heading">
								<p class="contact-detail-card__label">
									Call Us
								</p>
								<p class="contact-detail-card__value" aria-label="Phone number">
									705-525-PLAN (7526)
								</p>
							</div>
							<span class="contact-detail-card__icon icon-circle" aria-hidden="true">
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.46 19.46 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.91.33 1.8.63 2.65a2 2 0 0 1-.45 2.11L8 9.91a16 16 0 0 0 6.09 6.09l1.43-1.29a2 2 0 0 1 2.11-.45c.85.3 1.74.51 2.65.63A2 2 0 0 1 22 16.92Z" />
								</svg>
							</span>
						</div>
						<div class="contact-detail-card__actions">
							<button
								type="button"
								class="contact-copy-button"
								aria-label="Copy phone number"
								data-copy-value="705-525-PLAN (7526)"
								data-copy-label="Phone number"
							>
								Copy
							</button>
							<a href="tel:7055257526" class="contact-detail-card__link">
								Tap to Call
								<svg class="contact-detail-card__action-arrow h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M5 10h10" />
									<path d="m11 6 4 4-4 4" />
								</svg>
							</a>
						</div>
					</article>

					<article class="contact-detail-card ui-card">
						<div class="contact-detail-card__header">
							<div class="contact-detail-card__heading">
								<p class="contact-detail-card__label">
									Email Us
								</p>
								<p class="contact-detail-card__value contact-detail-card__value--email" aria-label="Email address">
									fdi@<wbr />financialdecisions<wbr />.ca
								</p>
							</div>
							<span class="contact-detail-card__icon icon-circle" aria-hidden="true">
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" />
									<path d="m22 7-10 7L2 7" />
								</svg>
							</span>
						</div>
						<div class="contact-detail-card__actions">
							<button
								type="button"
								class="contact-copy-button"
								aria-label="Copy email address"
								data-copy-value="fdi@financialdecisions.ca"
								data-copy-label="Email address"
							>
								Copy
							</button>
							<a href="mailto:fdi@financialdecisions.ca" class="contact-detail-card__link">
								Send an Email
								<svg class="contact-detail-card__action-arrow h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path d="M5 10h10" />
									<path d="m11 6 4 4-4 4" />
								</svg>
							</a>
						</div>
					</article>
				</div>
				<p class="contact-copy-status" aria-live="polite" data-copy-status></p>

				<section class="contact-location-panel reveal" aria-labelledby="contact-location-heading">
					<div class="contact-location-copy">
						<p class="inner-page-eyebrow">Office Location</p>
						<h2 id="contact-location-heading" class="page-title--section">
							1546 Bellevue Avenue
						</h2>
						<p class="page-subtext">
							Our office is located in Sudbury, Ontario, close to the corner of Bancroft Drive and Bellevue Avenue in Minnow Lake.
						</p>
						<div class="contact-location-details">
							<p>
								<span>Address</span>
								<strong>1546 Bellevue Avenue, Sudbury, ON, P3B 3G2</strong>
							</p>
							<p>
								<span>Phone</span>
								<strong>705-525-PLAN (7526)</strong>
							</p>
							<p>
								<span>Email</span>
								<strong>fdi@financialdecisions.ca</strong>
							</p>
						</div>
						<a href={mapsUrl} target="_blank" rel="noopener" class="btn btn-primary">
							Open in Google Maps
						</a>
					</div>

					<div class="contact-map-frame">
						<iframe
							src={mapsEmbedUrl}
							title="Google map showing the Financial Decisions office location"
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"
							allowfullscreen
						/>
					</div>
				</section>
			</div>
		</section>
	</main>
</Layout>

<script is:inline>
	(() => {
		const copyButtons = Array.from(document.querySelectorAll('[data-copy-value]'));
		const status = document.querySelector('[data-copy-status]');

		if (!copyButtons.length) return;

		const copyText = async (value) => {
			if (navigator.clipboard && window.isSecureContext) {
				await navigator.clipboard.writeText(value);
				return;
			}

			const textArea = document.createElement('textarea');
			textArea.value = value;
			textArea.setAttribute('readonly', '');
			textArea.style.position = 'fixed';
			textArea.style.top = '0';
			textArea.style.left = '-9999px';
			document.body.appendChild(textArea);
			textArea.select();
			document.execCommand('copy');
			document.body.removeChild(textArea);
		};

		copyButtons.forEach((button) => {
			button.addEventListener('click', async () => {
				const value = button.getAttribute('data-copy-value') || '';
				const label = button.getAttribute('data-copy-label') || 'Contact detail';
				const originalText = button.textContent?.trim() || 'Copy';

				try {
					await copyText(value);
					button.textContent = 'Copied';
					if (status) status.textContent = `${label} copied.`;

					window.setTimeout(() => {
						button.textContent = originalText;
						if (status) status.textContent = '';
					}, 2200);
				} catch {
					if (status) status.textContent = 'Copy failed. Please select the text manually.';
				}
			});
		});
	})();
</script>

<style>
	.contact-page {
		background:
			linear-gradient(180deg, rgba(var(--surface-page-tint-rgb), 0.88) 0%, rgba(var(--white-rgb), 1) 28rem),
			var(--surface-page);
	}

	.contact-methods-section {
		background: transparent;
	}

	.contact-methods-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(1rem, 2vw, 1.25rem);
		align-items: stretch;
		padding-top: clamp(1.5rem, 3vw, 2.25rem);
	}

	.contact-detail-card {
		position: relative;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 1.4rem;
		padding: 1.45rem;
		border-radius: var(--radius-md);
		border-color: rgba(var(--accent-rgb), 0.16);
		background: linear-gradient(
			180deg,
			rgba(var(--white-rgb), 0.96) 0%,
			rgba(var(--surface-warm-rgb), 0.9) 100%
		);
		box-shadow: 0 14px 34px rgba(var(--ink-shadow-rgb), 0.055);
	}

	.contact-detail-card::before {
		content: none;
	}

	.contact-detail-card.ui-card:hover {
		transform: none;
		border-color: rgba(var(--accent-rgb), 0.22);
		box-shadow: 0 16px 34px rgba(var(--ink-shadow-rgb), 0.07);
	}

	.contact-detail-card__header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
	}

	.contact-detail-card__heading {
		min-width: 0;
	}

	.contact-detail-card__label {
		margin: 0;
		font-size: var(--text-caption);
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--accent-dark);
	}

	.contact-detail-card__value {
		margin-top: 1rem;
		font-size: var(--text-contact-value);
		font-weight: 600;
		line-height: 1.2;
		letter-spacing: -0.022em;
		color: var(--ink-heading);
		text-wrap: balance;
		user-select: text;
		cursor: text;
	}

	.contact-detail-card__value p {
		margin: 0;
	}

	.contact-detail-card__value--email {
		font-size: clamp(1.05rem, 1.55vw, 1.24rem);
		line-height: 1.32;
		overflow-wrap: normal;
		word-break: normal;
		text-wrap: pretty;
	}

	.contact-detail-card__meta {
		margin-top: 0.45rem;
		font-size: var(--text-body-lg);
		font-weight: 500;
		letter-spacing: 0;
		line-height: 1.65;
		color: var(--ink-body);
	}

	.contact-detail-card__icon {
		display: flex;
		height: 2.7rem;
		width: 2.7rem;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		color: var(--accent);
	}

	.contact-detail-card__actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem 1rem;
		padding-top: 1.1rem;
		border-top: 1px solid rgba(var(--accent-rgb), 0.14);
	}

	.contact-copy-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.35rem;
		padding: 0.55rem 0.85rem;
		border: 1px solid rgba(var(--accent-rgb), 0.22);
		border-radius: var(--radius-xs);
		background: rgba(var(--white-rgb), 0.68);
		color: var(--accent-dark);
		font: inherit;
		font-size: var(--text-caption);
		font-weight: 700;
		line-height: 1.2;
		cursor: pointer;
		transition:
			background-color 180ms ease,
			border-color 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.contact-copy-button:hover {
		border-color: rgba(var(--accent-rgb), 0.34);
		background: var(--surface-warm-muted);
		color: var(--ink-heading);
		transform: translateY(-1px);
	}

	.contact-copy-button:active {
		transform: translateY(0) scale(0.985);
	}

	.contact-detail-card__link {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		font-size: var(--text-small);
		font-weight: 600;
		line-height: 1.4;
		color: var(--accent);
		text-decoration: none;
		transition: color 180ms ease;
	}

	.contact-detail-card__link:hover {
		color: var(--accent-dark);
		text-decoration-line: underline;
		text-decoration-color: currentColor;
	}

	.contact-detail-card__action-arrow {
		transition: transform 180ms ease;
	}

	.contact-detail-card__link:hover .contact-detail-card__action-arrow {
		transform: translateX(3px);
	}

	.contact-copy-status {
		min-height: 1.5rem;
		margin: 0.75rem 0 0;
		color: var(--accent-dark);
		font-size: var(--text-small);
		font-weight: 600;
		line-height: 1.5;
	}

	.contact-location-panel {
		display: grid;
		gap: clamp(1.5rem, 4vw, 2.75rem);
		align-items: center;
		margin-top: clamp(2rem, 4.5vw, 3.5rem);
		padding-top: clamp(2rem, 4.5vw, 3.5rem);
		border-top: 1px solid rgba(var(--accent-rgb), 0.16);
	}

	.contact-location-copy {
		max-width: 37rem;
	}

	.contact-location-copy .page-title--section {
		margin-top: 0.85rem;
	}

	.contact-location-details {
		display: grid;
		gap: 0.85rem;
		margin: 1.35rem 0 1.5rem;
	}

	.contact-location-details p {
		margin: 0;
		padding-top: 0.85rem;
		border-top: 1px solid rgba(var(--accent-rgb), 0.14);
	}

	.contact-location-details span {
		display: block;
		color: var(--accent-dark);
		font-size: var(--text-eyebrow);
		font-weight: 700;
		letter-spacing: 0.16em;
		line-height: 1.4;
		text-transform: uppercase;
	}

	.contact-location-details strong {
		display: block;
		margin-top: 0.35rem;
		color: var(--ink-heading);
		font-size: var(--text-body);
		font-weight: 600;
		line-height: 1.55;
	}

	.contact-map-frame {
		position: relative;
		display: block;
		overflow: hidden;
		border: 1px solid rgba(var(--accent-rgb), 0.18);
		border-radius: var(--radius-md);
		background: var(--surface-warm);
		box-shadow: 0 18px 38px rgba(var(--ink-shadow-rgb), 0.08);
	}

	.contact-map-frame iframe {
		display: block;
		width: 100%;
		aspect-ratio: 1.45;
		min-height: 22rem;
		border: 0;
		background: var(--surface-warm);
	}

	@media (min-width: 768px) {
		.contact-location-panel {
			grid-template-columns: minmax(0, 0.86fr) minmax(20rem, 1.14fr);
		}
	}

	@media (min-width: 640px) {
		.contact-detail-card {
			padding: 1.65rem;
		}
	}

	@media (max-width: 860px) {
		.contact-methods-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 639px) {
		.contact-detail-card__actions {
			align-items: stretch;
			flex-direction: column;
		}

		.contact-copy-button,
		.contact-detail-card__link {
			width: 100%;
			justify-content: center;
		}

		.contact-location-panel {
			margin-top: 2rem;
			padding-top: 2rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.contact-detail-card,
		.contact-detail-card__icon,
		.contact-detail-card__icon svg,
		.contact-detail-card__link,
		.contact-detail-card__action-arrow,
		.contact-copy-button {
			transition: none !important;
		}

		.contact-detail-card:hover,
		.contact-detail-card:active,
		.contact-detail-card__link:hover .contact-detail-card__action-arrow,
		.contact-copy-button:hover,
		.contact-copy-button:active {
			transform: none !important;
		}
	}
</style>
