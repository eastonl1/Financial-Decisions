---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="page-shell">
		<section class="contact-methods-section page-section-soft reveal no-divider">
			<div class="page-container page-container--content page-section--tight-top">
				<div class="contact-methods-grid grid gap-4 md:grid-cols-3 lg:gap-5">
					<a
						href="https://www.google.com/maps/search/?api=1&query=1546%20Bellevue%20Avenue%2C%20Sudbury%2C%20ON%2C%20P3B%203G2"
						target="_blank"
						rel="noopener"
						class="contact-method-card ui-card group flex h-full flex-col justify-between p-5 text-left text-slate-900 no-underline hover:no-underline focus-visible:no-underline sm:p-6"
					>
						<div class="flex items-start justify-between gap-4">
							<div class="min-w-0">
								<p class="contact-method-card__label">
									Visit Us
								</p>
								<p class="contact-method-card__value">
									1546 Bellevue Avenue
								</p>
								<p class="contact-method-card__meta">
									Sudbury, ON, P3B 3G2
								</p>
							</div>
							<span class="contact-method-card__icon icon-circle" aria-hidden="true">
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M12 21s7-4.35 7-11a7 7 0 1 0-14 0c0 6.65 7 11 7 11Z" />
									<circle cx="12" cy="10" r="2.5" />
								</svg>
							</span>
						</div>
						<span class="contact-method-card__action">
							Open in Maps
							<svg class="contact-method-card__action-arrow h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M6 14 14 6" />
								<path d="M7 6h7v7" />
							</svg>
						</span>
					</a>
					<a
						href="tel:7055257526"
						class="contact-method-card ui-card group flex h-full flex-col justify-between p-5 text-left text-slate-900 no-underline hover:no-underline focus-visible:no-underline sm:p-6"
					>
						<div class="flex items-start justify-between gap-4">
							<div class="min-w-0">
								<p class="contact-method-card__label">
									Call Us
								</p>
								<p class="contact-method-card__value">
									705-525-PLAN (7526)
								</p>
							</div>
							<span class="contact-method-card__icon icon-circle" aria-hidden="true">
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.46 19.46 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.91.33 1.8.63 2.65a2 2 0 0 1-.45 2.11L8 9.91a16 16 0 0 0 6.09 6.09l1.43-1.29a2 2 0 0 1 2.11-.45c.85.3 1.74.51 2.65.63A2 2 0 0 1 22 16.92Z" />
								</svg>
							</span>
						</div>
						<span class="contact-method-card__action">
							Tap to Call
							<svg class="contact-method-card__action-arrow h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M5 10h10" />
								<path d="m11 6 4 4-4 4" />
							</svg>
						</span>
					</a>
					<a
						href="mailto:fdi@financialdecisions.ca"
						class="contact-method-card ui-card group flex h-full flex-col justify-between p-5 text-left text-slate-900 no-underline hover:no-underline focus-visible:no-underline sm:p-6"
					>
						<div class="flex items-start justify-between gap-4">
							<div class="min-w-0">
								<p class="contact-method-card__label">
									Email Us
								</p>
								<p class="contact-method-card__value contact-method-card__value--email">
									fdi@financialdecisions.ca
								</p>
							</div>
							<span class="contact-method-card__icon icon-circle" aria-hidden="true">
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
									<path d="M4 5h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" />
									<path d="m22 7-10 7L2 7" />
								</svg>
							</span>
						</div>
						<span class="contact-method-card__action">
							Send an Email
							<svg class="contact-method-card__action-arrow h-3.5 w-3.5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M5 10h10" />
								<path d="m11 6 4 4-4 4" />
							</svg>
						</span>
					</a>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.contact-methods-grid {
		align-items: stretch;
	}

	.contact-method-card {
		position: relative;
		background: rgba(248, 244, 238, 0.7);
		padding: 1.45rem;
		will-change: transform, box-shadow;
	}

	.contact-method-card::before {
		content: '';
		position: absolute;
		left: 1.1rem;
		right: 1.1rem;
		top: 0;
		height: 2px;
		border-radius: 999px;
		background: linear-gradient(
			90deg,
			rgba(138, 107, 77, 0.12) 0%,
			rgba(138, 107, 77, 0.42) 50%,
			rgba(138, 107, 77, 0.12) 100%
		);
	}

	.contact-method-card:active {
		transform: translateY(-1px);
		box-shadow:
			0 10px 20px rgba(15, 23, 42, 0.06),
			inset 0 1px 0 rgba(255, 255, 255, 0.78);
	}

	.contact-method-card:focus-visible {
		outline: 3px solid rgba(138, 107, 77, 0.26);
		outline-offset: 4px;
	}

	.contact-method-card__label {
		font-size: 0.84rem;
		font-weight: 600;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #334155;
	}

	.contact-method-card__value {
		margin-top: 1rem;
		font-size: clamp(1.6rem, 2.5vw, 2rem);
		font-weight: 600;
		line-height: 1.18;
		letter-spacing: -0.03em;
		color: #0f172a;
		text-wrap: balance;
	}

	.contact-method-card__value--email {
		font-size: clamp(1.42rem, 2vw, 1.78rem);
		line-height: 1.22;
		overflow-wrap: anywhere;
		word-break: break-word;
		text-wrap: pretty;
	}

	.contact-method-card__meta {
		margin-top: 0.45rem;
		font-size: 1.02rem;
		line-height: 1.65;
		color: #475569;
	}

	.contact-method-card__icon {
		display: flex;
		height: 3rem;
		width: 3rem;
		flex: 0 0 auto;
		align-items: center;
		justify-content: center;
		color: var(--accent);
	}

	.contact-method-card__icon svg {
		transition: transform 180ms ease;
	}

	.contact-method-card:hover .contact-method-card__icon svg {
		transform: scale(1.04);
	}

	.contact-method-card__action {
		margin-top: 1.75rem;
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		font-size: 0.98rem;
		font-weight: 600;
		line-height: 1.4;
		color: var(--accent);
		transition: color 180ms ease;
	}

	.contact-method-card__action-arrow {
		transition: transform 180ms ease;
	}

	.contact-method-card:hover .contact-method-card__action-arrow {
		transform: translateX(3px);
	}

	@media (min-width: 640px) {
		.contact-method-card {
			padding: 1.65rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.contact-method-card,
		.contact-method-card__icon,
		.contact-method-card__icon svg,
		.contact-method-card__action,
		.contact-method-card__action-arrow {
			transition: none !important;
		}

		.contact-method-card:hover,
		.contact-method-card:active,
		.contact-method-card:hover .contact-method-card__icon,
		.contact-method-card:hover .contact-method-card__icon svg,
		.contact-method-card:hover .contact-method-card__action-arrow {
			transform: none !important;
		}
	}
</style>
