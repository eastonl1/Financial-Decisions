---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

const allInsights = await getCollection('blog', ({ data }) => !data.draft);
const sortedInsights = [...allInsights].sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestInsight = sortedInsights[0];
const latestInsightHref = latestInsight ? `/insights/newsletters/${latestInsight.slug}` : '/insights';

const formatInsightDate = (value: Date) =>
	new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' }).format(value);

const getInsightSummary = (entry: (typeof sortedInsights)[number]) =>
	entry.data.description?.trim() ||
	entry.data.issueItems?.[0] ||
	'Quarterly perspective on markets, planning, and financial decision-making.';
---

<Layout
	title="Financial Decisions | Independent Financial Planning in Sudbury"
	description="Locally owned and operated financial planning firm in Sudbury, providing guidance on investments, retirement, insurance, and long-term planning."
	heroPreload={{ href: '/images/office-painted.avif', type: 'image/avif' }}
>
	<main class="page-shell">
		<Hero
			title="Independent Financial Planning"
			subtitle="Locally owned and operated, we provide comprehensive guidance on investing, retirement, insurance, and long-term financial planning at every stage of life."
			eyebrow="FINANCIAL DECISIONS"
			backgroundImage="/images/office-painted.jpg"
			backgroundAvif="/images/office-painted.avif"
			backgroundWebp="/images/office-painted.webp"
			backgroundWidth="1536"
			backgroundHeight="1024"
			overlayClass="home-hero__overlay"
			className="home-hero"
			contentClass="home-hero__inner"
		>
			<div class="flex flex-wrap gap-3">
				<a
					href="/contact"
					class="btn btn-primary cta-button hero-cta no-link-style"
				>
					<span>Contact Us</span>
				</a>
			</div>
		</Hero>

		<section class="home-credibility-rail no-divider reveal" aria-label="Financial Decisions credibility highlights">
			<div class="page-container">
				<div class="home-credibility-rail__shell">
					<header class="home-credibility-rail__header">
						<p class="eyebrow">Why Clients Stay</p>
						<p class="home-credibility-rail__lede">
							Steady financial guidance for individuals and families across every life stage.
						</p>
					</header>
					<ul class="home-credibility-rail__list" aria-label="Firm credibility highlights">
						<li class="home-credibility-rail__item home-credibility-rail__item--anchor">
							<span class="home-credibility-rail__item-label">Established</span>
							<span class="home-credibility-rail__item-title">
								<span class="home-credibility-rail__item-figure">25+</span>
								<span class="home-credibility-rail__item-unit">years</span>
							</span>
							<span class="home-credibility-rail__item-copy">Serving clients through changing life stages</span>
						</li>
						<li class="home-credibility-rail__item">
							<span class="home-credibility-rail__item-label">Recognized</span>
							<span class="home-credibility-rail__item-title">Three-time Favorite Financial Planner</span>
							<span class="home-credibility-rail__item-copy">Community reader polls in Greater Sudbury</span>
						</li>
						<li class="home-credibility-rail__item">
							<span class="home-credibility-rail__item-label">Credentials</span>
							<span class="home-credibility-rail__item-title">CFP &middot; R.F.P. &middot; CFDS</span>
							<span class="home-credibility-rail__item-copy">Advanced planning designations held by the firm&rsquo;s lead planner</span>
						</li>
						<li class="home-credibility-rail__item">
							<span class="home-credibility-rail__item-label">Family-led</span>
							<span class="home-credibility-rail__item-title">Locally owned and operated</span>
							<span class="home-credibility-rail__item-copy">Linda Cartier and Melanie Cartier</span>
						</li>
					</ul>
				</div>
			</div>
		</section>

		<section class="home-planning-philosophy-section reveal no-divider" aria-labelledby="planning-philosophy-title">
			<div class="page-container page-container--content">
				<div class="home-planning-philosophy-shell">
					<div class="home-planning-philosophy-intro">
						<p class="eyebrow">PLANNING PHILOSOPHY</p>
						<h2 id="planning-philosophy-title" class="home-planning-philosophy-title">
							Our Approach
						</h2>
					</div>
					<div class="home-planning-philosophy-content">
						<p class="home-planning-philosophy-body">
							Financial planning is personal, thoughtful, and long-term. It is about making thoughtful decisions in the context of your goals, responsibilities, and the life you want to build over time. Our role is to help clients understand their options clearly, plan with discipline, and move forward with confidence.
						</p>
						<p class="home-planning-philosophy-supporting">
							That approach has guided our work with clients and families for more than two decades.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section class="home-planning-areas-section reveal no-divider" aria-labelledby="planning-areas-title">
			<div class="page-container page-container--content">
				<div class="home-planning-areas-shell">
					<header class="home-planning-areas-intro">
						<p class="eyebrow">PLANNING AREAS</p>
						<h2 id="planning-areas-title" class="home-planning-areas-title">
							Planning That Adapts to Real Life
						</h2>
						<p class="home-planning-areas-lead">
							Comprehensive guidance means looking at the full picture, not isolated decisions.
						</p>
					</header>
					<ol class="home-planning-areas-list" aria-label="Financial planning areas of focus">
						<li>
							<h3 class="home-planning-areas-heading">Retirement Planning</h3>
							<p class="home-planning-areas-copy">Preparing for income, lifestyle, and long-term stability.</p>
						</li>
						<li>
							<h3 class="home-planning-areas-heading">Investment Guidance</h3>
							<p class="home-planning-areas-copy">Aligning portfolios with goals, risk, and time horizon.</p>
						</li>
						<li>
							<h3 class="home-planning-areas-heading">Insurance and Protection</h3>
							<p class="home-planning-areas-copy">Protecting what matters through appropriate coverage.</p>
						</li>
						<li>
							<h3 class="home-planning-areas-heading">Tax-Aware Planning</h3>
							<p class="home-planning-areas-copy">Making decisions with long-term efficiency in mind.</p>
						</li>
						<li>
							<h3 class="home-planning-areas-heading">Estate and Legacy Considerations</h3>
							<p class="home-planning-areas-copy">Planning for continuity, family, and future wishes.</p>
						</li>
						<li>
							<h3 class="home-planning-areas-heading">Separation and Divorce Guidance</h3>
							<p class="home-planning-areas-copy">Specialized support where financial decisions require added care.</p>
						</li>
					</ol>
				</div>
			</div>
		</section>

		<section class="home-local-roots-section reveal no-divider" aria-labelledby="local-roots-title">
			<div class="page-container page-container--content">
				<div class="home-local-roots-shell">
					<div class="home-local-roots-copy">
						<p class="eyebrow">TRUST</p>
						<h2 id="local-roots-title" class="home-local-roots-title">
							Built on Relationships
						</h2>
						<p class="home-local-roots-body">
							Financial Decisions has always been built on relationships. We work with individuals, couples, and families over time, helping them make thoughtful financial decisions as life changes. That long view is personal, steady, and grounded in trust.
						</p>
						<p class="home-local-roots-closing">
							Personal in approach. Long-term in perspective.
						</p>
					</div>
					<figure class="home-local-roots-media">
						<div class="home-local-roots-media__frame">
							<img
								src="/images/Meeting.jpg"
								alt="Financial Decisions meeting with clients"
								class="home-local-roots-media__image"
								width="578"
								height="381"
								loading="lazy"
								decoding="async"
							/>
						</div>
					</figure>
				</div>
			</div>
		</section>

		<section class="home-advisor-recognition-section reveal no-divider" aria-labelledby="advisor-recognition-title">
			<div class="page-container page-container--content">
				<div class="home-advisor-recognition-shell">
					<figure class="home-advisor-recognition-media">
						<div class="home-advisor-recognition-media__frame">
							<img
								src="/images/Linda.jpg"
								alt="Linda Cartier"
								class="home-advisor-recognition-media__image"
								width="340"
								height="387"
								loading="lazy"
								decoding="async"
							/>
						</div>
					</figure>
					<div class="home-advisor-recognition-copy">
						<p class="eyebrow">Professional Background</p>
						<h2 id="advisor-recognition-title" class="home-advisor-recognition-title">
							Experience That Clients Have Come to Rely On
						</h2>
						<p class="home-advisor-recognition-body">
							Financial Decisions is led by Linda Cartier, whose work reflects a long-standing commitment to financial planning, education, and higher professional standards. Her background includes teaching the CFP course at Cambrian College, leading financial education for the public, and holding advanced planning designations including CFP, R.F.P., PRP, ELP, and CFDS.
						</p>
						<ul class="home-advisor-recognition-highlights" aria-label="Advisor recognition highlights">
							<li>Certified and specialized planning credentials</li>
							<li>Financial education and teaching experience</li>
							<li>Trusted by clients over many years</li>
						</ul>
						<a href="/about" class="btn btn-secondary home-advisor-recognition-cta no-link-style">
							<span>Learn More About Our Team</span>
						</a>
					</div>
				</div>
			</div>
		</section>

		<section class="home-recognition-proof-section reveal no-divider" aria-label="Recognition and testimonial highlight">
			<div class="page-container page-container--content">
				<div class="home-recognition-proof-shell">
					<p class="eyebrow">Recognition</p>
					<h2 class="home-recognition-proof-title">What Clients Have Said</h2>
					<div class="home-recognition-proof-quotes" aria-label="Client testimonials">
						<blockquote class="home-recognition-proof-quote">
							<p>&ldquo;Linda takes the time to get to know her clients and provide the most comprehensive financial plans I have ever seen.&rdquo;</p>
							<cite class="home-recognition-proof-source">Talbot Stevens, Financial Speaker, Educator and Author</cite>
						</blockquote>
						<blockquote class="home-recognition-proof-quote">
							<p>&ldquo;Linda possesses extensive knowledge and the patience to assist people in coming to a full understanding of their financial situation and to assist them in constructive solutions.&rdquo;</p>
							<cite class="home-recognition-proof-source">D.M Thomson, R.N. B.A. B.ScN</cite>
						</blockquote>
					</div>
					<a href="/about#recognition" class="btn btn-secondary home-recognition-proof-cta no-link-style">
						<span>See What Clients Have to Say</span>
					</a>
				</div>
			</div>
		</section>

		<section class="home-insights-preview-section reveal no-divider" aria-labelledby="home-insights-preview-title">
			<div class="page-container page-container--content">
				<div class="home-insights-preview-shell">
					<header class="home-insights-preview-header">
						<p class="eyebrow">Recent Insights</p>
						<h2 id="home-insights-preview-title" class="home-insights-preview-title">
							Latest Newsletter
						</h2>
						<p class="home-insights-preview-intro">
							Quarterly newsletters and video updates that reflect our ongoing perspective on markets, planning, and financial decision-making.
						</p>
					</header>

					{latestInsight ? (
						<article class="home-insights-latest-item" aria-label="Most recent newsletter">
							<a href={latestInsightHref} class="home-insights-latest-media no-link-style">
								{latestInsight.data.image ? (
									<img
										src={latestInsight.data.image}
										alt={`${latestInsight.data.title} newsletter cover image`}
										width="720"
										height="540"
										loading="lazy"
										decoding="async"
									/>
								) : (
									<div class="home-insights-latest-media-fallback" aria-hidden="true">
										<span>Financial Decisions</span>
									</div>
								)}
							</a>
							<div class="home-insights-latest-content">
								<div class="home-insights-item-meta-row">
									<p class="home-insights-item-label">Featured Issue</p>
									<p class="home-insights-item-meta">
										{formatInsightDate(latestInsight.data.pubDate)} &middot; {latestInsight.data.readingTime}
									</p>
								</div>
								<h3 class="home-insights-item-title">
									<a href={latestInsightHref} class="no-link-style">
										{latestInsight.data.title}
									</a>
								</h3>
								<p class="home-insights-item-copy">
									{getInsightSummary(latestInsight)}
								</p>
								<div class="home-insights-item-details">
									{latestInsight.data.issueItems && latestInsight.data.issueItems.length > 0 && (
										<div class="home-insights-item-hook" aria-label="Newsletter highlights">
											<p class="home-insights-item-hook-label">In this issue</p>
											<ul class="home-insights-item-hook-list">
												{latestInsight.data.issueItems.slice(0, 3).map((item) => (
													<li>{item}</li>
												))}
											</ul>
										</div>
									)}
									<div class="home-insights-item-support">
										<p class="home-insights-item-support-label">Archive</p>
										<p class="home-insights-item-support-copy">
											Review recent issues and video updates in one place.
										</p>
										{latestInsight.data.pdfPath && (
											<a
												href={latestInsight.data.pdfPath}
												class="home-insights-item-support-link"
												target="_blank"
												rel="noopener"
											>
												Open PDF version
											</a>
										)}
									</div>
								</div>
								<div class="home-insights-latest-actions">
									<a
										href={latestInsightHref}
										class="btn btn-primary home-insights-latest-link no-link-style"
									>
										<span>Read Latest Newsletter</span>
									</a>
									<a href="/insights" class="btn btn-secondary home-insights-archive-link no-link-style">
										<span>View All Newsletters</span>
									</a>
								</div>
							</div>
						</article>
					) : (
						<p class="home-insights-preview-empty">Insights will appear here as new updates are published.</p>
					)}

					{!latestInsight && (
						<a href="/insights" class="btn btn-secondary home-insights-preview-cta no-link-style">
							<span>View All Newsletters</span>
						</a>
					)}
				</div>
			</div>
		</section>

		<section class="home-closing-cta-section reveal no-divider" aria-labelledby="home-closing-cta-title">
			<div class="page-container page-container--content">
				<div class="home-closing-cta-shell">
					<h2 id="home-closing-cta-title" class="home-closing-cta-title">
						Start With a Conversation
					</h2>
					<p class="home-closing-cta-body">
						Whether you are planning for retirement, reviewing your current strategy, or looking for clearer direction, we welcome the opportunity to speak with you.
					</p>
					<a href="/contact" class="btn btn-primary home-closing-cta-button no-link-style">
						<span>Contact Us</span>
					</a>
					<p class="home-closing-cta-contact">
						1546 Bellevue Avenue, Sudbury, Ontario | 705-525-PLAN
					</p>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.home-credibility-rail {
		position: relative;
		padding-block: clamp(2.4rem, 4vw, 3.2rem);
		background: var(--surface-band);
	}

	.home-credibility-rail__shell {
		display: grid;
		gap: 0;
	}

	.home-credibility-rail__header {
		margin: 0 auto;
		max-width: 52rem;
		padding: 0 clamp(0.5rem, 2vw, 1rem) clamp(1.5rem, 2.8vw, 2rem);
		text-align: center;
	}

	.home-credibility-rail__header .eyebrow {
		color: var(--accent);
	}

	.home-credibility-rail__lede {
		margin: 0.85rem auto 0;
		max-width: 44rem;
		font-size: var(--text-proof-lede);
		font-weight: 500;
		line-height: 1.55;
		letter-spacing: -0.015em;
		color: var(--ink-heading);
		text-wrap: balance;
	}

	.home-credibility-rail__list {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: 0;
		margin: 0;
		padding: 0;
		list-style: none;
		border-top: 1px solid var(--rule-bronze);
		border-bottom: 1px solid var(--rule-bronze);
	}

	.home-credibility-rail__item {
		position: relative;
		display: grid;
		grid-template-rows: auto 1fr auto;
		row-gap: 0.85rem;
		min-height: 7.75rem;
		padding: 1.4rem clamp(1rem, 2vw, 1.45rem) 1.35rem;
		text-align: left;
		border-top: 1px solid var(--rule-bronze-soft);
	}

	.home-credibility-rail__item:not(.home-credibility-rail__item--anchor) {
		grid-template-rows: auto auto auto;
		row-gap: 0.75rem;
	}

	.home-credibility-rail__item:first-child {
		border-top: none;
	}

	.home-credibility-rail__item-label {
		display: block;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: var(--eyebrow-tracking);
		line-height: 1.2;
		text-transform: uppercase;
		color: var(--accent-dark);
	}

	.home-credibility-rail__item-title {
		align-self: center;
		display: block;
		max-width: 26ch;
		font-size: 1.18rem;
		font-weight: 600;
		letter-spacing: -0.012em;
		line-height: 1.3;
		color: var(--ink-heading);
		text-wrap: balance;
	}
	.home-credibility-rail__item:not(.home-credibility-rail__item--anchor) .home-credibility-rail__item-title {
		align-self: start;
		min-height: calc(1.3em * 2);
	}

	.home-credibility-rail__item--anchor .home-credibility-rail__item-title {
		display: flex;
		align-items: baseline;
		gap: 0.4rem;
		max-width: none;
	}

	.home-credibility-rail__item-figure {
		font-size: var(--text-proof-figure);
		font-weight: 600;
		line-height: 0.95;
		letter-spacing: -0.045em;
		color: var(--ink-heading);
	}

	.home-credibility-rail__item-unit {
		font-size: var(--text-body-lg);
		font-weight: 500;
		letter-spacing: -0.01em;
		color: var(--ink-soft);
	}

	.home-credibility-rail__item-copy {
		align-self: end;
		display: block;
		max-width: 30ch;
		font-size: var(--text-small);
		line-height: 1.6;
		color: var(--ink-body);
		text-wrap: pretty;
	}
	.home-credibility-rail__item:not(.home-credibility-rail__item--anchor) .home-credibility-rail__item-copy {
		align-self: start;
		min-height: calc(1.6em * 2);
	}

	.home-planning-philosophy-section {
		position: relative;
		padding-block: clamp(3rem, 5vw, 4.2rem) clamp(3.1rem, 5.2vw, 4.4rem);
		background: var(--surface-band);
	}

	.home-planning-philosophy-section .page-container--content {
		display: grid;
		place-items: center;
	}

	.home-planning-philosophy-shell {
		position: relative;
		display: grid;
		gap: clamp(1.5rem, 2.4vw, 2.2rem);
		width: min(100%, 72rem);
		max-width: 72rem;
		margin: 0 auto;
		padding: clamp(1.65rem, 3vw, 2.35rem) clamp(1.3rem, 2.8vw, 2.05rem);
		border: none;
		border-radius: 0;
		background: transparent;
		box-shadow: none;
	}

	.home-planning-philosophy-intro,
	.home-planning-philosophy-content {
		position: relative;
		z-index: 1;
		width: 100%;
		margin-inline: auto;
	}

	.home-planning-philosophy-intro {
		text-align: center;
	}

	.home-planning-philosophy-content {
		text-align: center;
	}

	.home-planning-philosophy-intro .eyebrow {
		color: var(--accent);
	}

	.home-planning-philosophy-title {
		margin-top: 0.9rem;
		margin-inline: auto;
		width: fit-content;
		max-width: 100%;
		font-size: var(--text-section-title);
		font-weight: 600;
		line-height: 1.1;
		letter-spacing: -0.03em;
		color: var(--ink-heading);
		text-wrap: balance;
	}

	.home-planning-philosophy-body {
		max-width: 47rem;
		margin-inline: auto;
		text-align: center;
		font-size: var(--text-body-lg);
		line-height: 1.86;
		color: var(--ink-body);
	}

	.home-planning-philosophy-supporting {
		margin-top: 1.2rem;
		margin-inline: auto;
		max-width: 47rem;
		text-align: center;
		font-size: var(--text-body);
		line-height: 1.72;
		letter-spacing: 0.01em;
		color: var(--accent-copy);
	}

	.home-planning-areas-section {
		position: relative;
		padding-block: clamp(2.55rem, 4.4vw, 3.75rem) clamp(3.1rem, 5vw, 4.25rem);
		background: var(--surface-page);
	}

	.home-planning-areas-shell {
		max-width: 72rem;
		margin: 0 auto;
	}

	.home-planning-areas-intro {
		max-width: 44rem;
		margin: 0 auto;
		text-align: center;
	}

	.home-planning-areas-intro .eyebrow {
		color: var(--accent);
	}

	.home-planning-areas-title {
		margin-top: 0.9rem;
		font-size: var(--text-section-title);
		font-weight: 600;
		line-height: 1.12;
		letter-spacing: -0.03em;
		color: var(--ink-heading);
		text-wrap: balance;
	}

	.home-planning-areas-lead {
		margin-top: 1.1rem;
		font-size: var(--text-body-lg);
		line-height: 1.8;
		color: var(--ink-body);
	}

	.home-planning-areas-list {
		counter-reset: planning-area;
		display: grid;
		gap: 0;
		margin: clamp(2rem, 3.5vw, 2.85rem) auto 0;
		padding: 0;
		list-style: none;
		border-top: 1px solid var(--rule-bronze);
		max-width: 68rem;
	}

	.home-planning-areas-list li {
		counter-increment: planning-area;
		position: relative;
