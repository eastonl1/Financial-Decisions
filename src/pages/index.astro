---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout>
	<main>
		<Hero
			title="Home Town Office with a Global Perspective"
			subtitle='Locally owned and operated - proud to be Canadian'
			eyebrow="Financial Decisions"
			backgroundImage="/images/Office%20Painted.png"
			className="home-hero"
			contentClass="py-12 sm:py-16 lg:py-20"
		>
			<div class="flex flex-wrap gap-3">
				<a
					href="/contact"
					class="no-link-style btn-accent rounded-md px-5 py-3 text-sm font-semibold transition"
				>
					Contact Us
				</a>
			</div>
		</Hero>

		<section class="home-section home-section--alt reveal no-divider">
			<div class="container mx-auto px-6 home-section__inner">
				<div class="grid gap-12 lg:grid-cols-2 lg:items-center">
					<div class="home-prose">
						<p class="eyebrow text-[color:var(--accent)]">
							Community
						</p>
						<h2 class="mt-3 text-[2rem] font-semibold tracking-tight text-slate-900">
							Connected to the people we serve
						</h2>
						<p class="mt-4 text-base text-slate-600">
							Proudly serving the lifestyle, financial planning and insurance needs of
							hundreds of individuals, couples and families in the Greater Sudbury
							area and beyond who we consider to be friends as well as clients.
						</p>
					</div>
					<div class="overflow-hidden rounded-lg shadow-sm lg:max-w-sm lg:justify-self-center">
						<img
							src="/images/Meeting.jpg"
							alt="Meeting with clients"
							class="h-full w-full object-cover"
							loading="lazy"
							decoding="async"
						/>
					</div>
				</div>
			</div>
		</section>

		<section class="home-section reveal">
			<div class="container mx-auto px-6 home-section__inner">
				<div class="grid gap-12 lg:grid-cols-2 lg:items-center">
					<div class="home-prose order-2 lg:order-2">
						<p class="eyebrow text-[color:var(--accent)]">
							Mission
						</p>
						<h2 class="mt-3 text-[2rem] font-semibold tracking-tight text-slate-900">
							Committed to your peace of mind
						</h2>
						<p class="mt-4 text-base text-slate-600">
							Our dedicated mission for over 25 years is to bring to our valued clients
							peace of mind as they understand we care about their financial well being
							as if it were our own and specifically this is our continuing commitment.
						</p>
					</div>
					<div class="order-1 overflow-hidden rounded-lg shadow-sm lg:order-1 lg:justify-self-center lg:max-w-[220px]">
						<img
							src="/images/Award.jpg"
							alt="Award recognition"
							class="h-full w-full object-cover"
							loading="lazy"
							decoding="async"
						/>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>
