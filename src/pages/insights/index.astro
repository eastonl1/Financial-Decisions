---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import { getCollection } from 'astro:content';

const insights = await getCollection('insights');
const sorted = [...insights].sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const [latest, ...archive] = sorted;
const formatDate = (date) =>
	new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(date);
---

<Layout>
	<main>
		<Hero
			title="Insights"
			subtitle="Thoughtful updates and seasonal newsletters from the Financial Decisions team."
		/>

		<section class="bg-white">
			<div class="container mx-auto px-6 py-10 sm:py-12">
				{latest ? (
					<section class="rounded-lg border border-[color:var(--accent-muted)] bg-stone-50 p-6 sm:p-8">
						<p class="eyebrow text-[color:var(--accent)]">Latest Issue</p>
						<h2 class="mt-3 text-2xl font-semibold text-slate-900 sm:text-3xl">
							{latest.data.title}
						</h2>
						<p class="mt-2 text-sm text-slate-600">{formatDate(latest.data.date)}</p>
						{latest.data.description && (
							<p class="mt-4 text-sm text-slate-600">{latest.data.description}</p>
						)}
						<div class="mt-5 flex flex-wrap gap-3">
							<a
								href={`/insights/${latest.slug}`}
								class="inline-flex items-center text-sm font-semibold text-[color:var(--accent)] hover:text-[color:var(--accent-dark)]"
							>
								Read the latest issue
							</a>
							{latest.data.pdf && (
								<a
									href={latest.data.pdf}
									class="inline-flex items-center rounded-md border border-[color:var(--accent-muted)] bg-white px-4 py-2 text-sm font-semibold text-[color:var(--accent)] transition hover:border-[color:var(--accent)] hover:text-[color:var(--accent-dark)]"
								>
									Download PDF
								</a>
							)}
						</div>
					</section>
				) : (
					<p class="text-sm text-slate-600">No insights are available yet.</p>
				)}

				{archive.length > 0 && (
					<section class="mt-10">
						<h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-600">
							Archive
						</h3>
						<div class="mt-4 grid gap-4 sm:grid-cols-2">
							{archive.map((entry) => (
								<article class="rounded-lg border border-[color:var(--accent-muted)] bg-white p-5">
									<p class="text-base font-semibold text-slate-900">{entry.data.title}</p>
									<p class="mt-2 text-sm text-slate-600">{formatDate(entry.data.date)}</p>
									{entry.data.description && (
										<p class="mt-3 text-sm text-slate-600">{entry.data.description}</p>
									)}
									<div class="mt-4 flex flex-wrap items-center gap-3">
										<a
											href={`/insights/${entry.slug}`}
											class="text-sm font-semibold text-[color:var(--accent)] hover:text-[color:var(--accent-dark)]"
										>
											Read
										</a>
										{entry.data.pdf && (
											<a
												href={entry.data.pdf}
												class="text-xs font-semibold uppercase tracking-[0.18em] text-[color:var(--accent-dark)]"
											>
												PDF
											</a>
										)}
									</div>
								</article>
							))}
						</div>
					</section>
				)}
			</div>
		</section>
	</main>
</Layout>
