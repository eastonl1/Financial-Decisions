---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import { newsletters } from '../../data/newsletters';

const sorted = [...newsletters].sort(
	(a, b) => new Date(b.date).valueOf() - new Date(a.date).valueOf()
);
const [latest] = sorted;
const libraryEntries = latest ? sorted.filter((entry) => entry.slug !== latest.slug) : sorted;
const formatDateString = (value) =>
	new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(
		new Date(value)
	);
---

<Layout>
	<main>
		<Hero
			title="Newsletters"
			subtitle="Posts and newsletters from the Financial Decisions team."
		/>

		<section class="bg-white">
			<div class="container mx-auto px-6 py-10 sm:py-12">
				{latest ? (
					<section class="rounded-lg border border-[color:var(--accent-muted)] bg-stone-50 p-6 sm:p-8">
						<p class="eyebrow text-[color:var(--accent)]">Latest Issue</p>
						<h2 class="mt-3 text-2xl font-semibold text-slate-900 sm:text-3xl">
							{latest.title}
						</h2>
						<p class="mt-2 text-sm text-slate-600">{formatDateString(latest.date)}</p>
						{latest.description && (
							<p class="mt-4 text-sm text-slate-600">{latest.description}</p>
						)}
						<div class="mt-5 flex flex-wrap gap-3">
							<a
								href={`/insights/newsletters/${latest.slug}`}
								class="btn btn-primary"
							>
								View the latest issue
							</a>
							<a
								href={latest.pdfPath}
								class="btn-link hover:underline underline-offset-4"
							>
								Download PDF
							</a>
						</div>
					</section>
				) : (
					<p class="text-sm text-slate-600">No newsletters are available yet.</p>
				)}

				<section class="mt-10 rounded-lg border border-[color:var(--accent-muted)] bg-white p-6 sm:p-8">
					<p class="eyebrow text-[color:var(--accent)]">Newsletters</p>
					<h2 class="mt-3 text-2xl font-semibold text-slate-900 sm:text-3xl">
						PDF Library
					</h2>
					<p class="mt-2 text-sm text-slate-600">
						Download or view recent newsletters in a clean, print-ready format.
					</p>
					<div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
						{libraryEntries.map((entry) => (
							<article class="rounded-lg border border-[color:rgba(148,163,184,0.35)] bg-white p-5">
								<p class="text-base font-semibold text-slate-900">{entry.title}</p>
								<p class="mt-2 text-sm text-slate-600">
									{formatDateString(entry.date)}
								</p>
								{entry.description && (
									<p class="mt-3 text-sm text-slate-600">{entry.description}</p>
								)}
								<div class="mt-4 flex flex-wrap gap-3">
									<a
										href={`/insights/newsletters/${entry.slug}`}
										class="btn btn-primary btn-sm"
										aria-label={`View ${entry.title}`}
									>
										View
									</a>
									<a
										href={entry.pdfPath}
										class="btn-link text-xs hover:underline underline-offset-4"
										aria-label={`Download ${entry.title} PDF`}
									>
										Download PDF
									</a>
								</div>
							</article>
						))}
					</div>
				</section>
			</div>
		</section>
	</main>
</Layout>
