---
import Layout from '../../../layouts/Layout.astro';
import Hero from '../../../components/Hero.astro';
import PdfJsViewer from '../../../components/PdfJsViewer.astro';
import { newsletters } from '../../../data/newsletters';

export async function getStaticPaths() {
	return newsletters.map((entry) => ({
		params: { slug: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const formatDate = (value) =>
	new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(
		new Date(value)
	);
---

<Layout>
	<main>
		<Hero
			title="Newsletters"
			subtitle="Posts and newsletters from the Financial Decisions team."
		/>

		<section class="bg-white">
			<div class="container mx-auto px-6 py-10 sm:py-12">
				<article class="rounded-lg border border-[color:var(--accent-muted)] bg-white p-6 sm:p-8">
					<div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
						<div>
							<p class="eyebrow text-[color:var(--accent)]">Newsletters</p>
							<h1 class="mt-3 text-2xl font-semibold text-slate-900 sm:text-3xl">
								{entry.title}
							</h1>
							<p class="mt-2 text-sm text-slate-600">{formatDate(entry.date)}</p>
						</div>
						<div class="hidden md:flex md:flex-wrap md:items-center md:justify-end md:gap-3">
							<a
								href="/insights"
								class="btn btn-primary"
							>
								Back to Newsletters
							</a>
							<a
								href={entry.pdfPath}
								target="_blank"
								rel="noopener"
								class="btn btn-secondary"
							>
								Open PDF
							</a>
							<a
								href={entry.pdfPath}
								download
								class="btn btn-secondary"
							>
								Download PDF
							</a>
						</div>
					</div>

					{entry.description && (
						<p class="mt-4 text-sm text-slate-600">{entry.description}</p>
					)}

					<div class="mt-6 rounded-md border border-[color:var(--accent-muted)] bg-stone-50 p-4 md:hidden">
						<p class="text-sm text-slate-600">
							Reading on your phone? Opening the PDF is usually easier.
						</p>
						<div class="mt-3 flex flex-wrap gap-3">
							<a href={entry.pdfPath} target="_blank" rel="noopener" class="btn btn-primary">
								Open PDF
							</a>
							<a href={entry.pdfPath} download class="btn btn-secondary">
								Download PDF
							</a>
						</div>
						<button
							type="button"
							data-mobile-viewer-toggle
							aria-controls="mobile-newsletter-viewer"
							aria-expanded="false"
							class="btn-link mt-3"
						>
							Show embedded viewer
						</button>
					</div>

					<div class="mt-6 hidden md:block">
						<PdfJsViewer pdfUrl={entry.pdfPath} title={entry.title} />
					</div>

					<div id="mobile-newsletter-viewer" data-mobile-newsletter-viewer class="mt-6 hidden md:hidden">
						<PdfJsViewer pdfUrl={entry.pdfPath} title={entry.title} />
					</div>

					<div class="mt-5 hidden md:flex md:flex-wrap md:gap-3">
						<a
							href={entry.pdfPath}
							target="_blank"
							rel="noopener"
							class="btn btn-secondary"
						>
							Open PDF
						</a>
						<a
							href={entry.pdfPath}
							download
							class="btn btn-secondary"
						>
							Download PDF
						</a>
						<a
							href="/insights"
							class="btn btn-primary"
						>
							Back to Newsletters
						</a>
					</div>
				</article>
			</div>
		</section>
	</main>
</Layout>

<script>
	const toggle = document.querySelector('[data-mobile-viewer-toggle]');
	const viewer = document.querySelector('[data-mobile-newsletter-viewer]');

	if (toggle && viewer) {
		toggle.addEventListener('click', () => {
			const isHidden = viewer.classList.contains('hidden');
			viewer.classList.toggle('hidden', !isHidden);
			toggle.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
			toggle.textContent = isHidden ? 'Hide embedded viewer' : 'Show embedded viewer';
			if (isHidden) viewer.scrollIntoView({ behavior: 'smooth', block: 'start' });
		});
	}
</script>
