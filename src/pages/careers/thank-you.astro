---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
	<main>
		<section class="bg-white min-h-[60vh] reveal">
			<div class="page-container page-container--content py-10 sm:py-12">
				<article class="rounded-lg border border-[color:var(--accent-muted)] bg-white p-6 sm:p-8">
					<h2 class="inner-page-section-title">Application Submitted</h2>
					<p class="inner-page-body mt-3">
						Thank you for your interest in joining Financial Decisions. We appreciate the
						time and care you put into your application.
					</p>
					<p class="inner-page-body mt-3">
						Our team will review your submission as soon as possible. If your background
						aligns with what we are looking for, we will follow up by email with next
						steps.
					</p>
					<p class="inner-page-body mt-3">
						We value thoughtful professionals who care deeply about helping clients make
						confident financial decisions, and we are grateful for your interest in our
						firm.
					</p>

					<div class="mt-6 flex flex-wrap items-center gap-3">
						<a
							href="/careers"
							class="btn btn-primary"
						>
							Back to Careers
						</a>
						<a
							href="/"
							class="btn-link"
						>
							Return Home
						</a>
					</div>
				</article>
			</div>
		</section>
	</main>
</Layout>
