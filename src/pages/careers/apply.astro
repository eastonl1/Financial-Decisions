---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';

const defaultPosting = 'General Application';
const maxFileSizeMb = 5;
---

<Layout>
	<main>
		<Hero
			title="Apply"
			subtitle="Submit your application and tell us about your interest in joining the team."
		/>

		<section class="bg-white min-h-[60vh] reveal">
			<div class="container mx-auto px-6 py-10 sm:py-12">
				<article class="rounded-lg border border-[color:var(--accent-muted)] bg-white p-6 sm:p-8">
					<h2 class="text-2xl font-semibold text-slate-900">Application Form</h2>
					<p class="mt-2 text-sm text-slate-700">
						You can apply for a specific posting or submit a general application.
					</p>

					<form
						class="mt-6 space-y-5"
						name="career-application"
						method="POST"
						action="/careers/thank-you"
						data-netlify="true"
						data-netlify-honeypot="bot-field"
						data-netlify-recaptcha="true"
						enctype="multipart/form-data"
						id="career-application-form"
					>
						<input type="hidden" name="form-name" value="career-application" />
						<p class="hidden">
							<label>
								Do not fill this out if you are human:
								<input name="bot-field" />
							</label>
						</p>

						<div>
							<label for="name" class="block text-sm font-semibold text-slate-800">Name</label>
							<input
								id="name"
								name="name"
								type="text"
								required
								class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-[color:var(--accent)]"
							/>
						</div>

						<div>
							<label for="posting" class="block text-sm font-semibold text-slate-800">Posting</label>
							<input
								id="posting"
								name="posting"
								type="text"
								value={defaultPosting}
								required
								class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-[color:var(--accent)]"
							/>
						</div>

						<div>
							<label for="email" class="block text-sm font-semibold text-slate-800">Email</label>
							<input
								id="email"
								name="email"
								type="email"
								required
								class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-[color:var(--accent)]"
							/>
						</div>

						<div>
							<label for="message" class="block text-sm font-semibold text-slate-800">
								Message (optional)
							</label>
							<textarea
								id="message"
								name="message"
								rows="6"
								class="mt-2 w-full rounded-md border border-slate-300 px-3 py-2 text-sm text-slate-900 outline-none transition focus:border-[color:var(--accent)]"
							></textarea>
						</div>

						<div class="mt-3">
							<p class="block text-sm font-semibold text-slate-800">
								Add resume and cover letter
							</p>
							<p class="mt-1 text-xs text-slate-700">
								Resume is required. Cover letter is optional. PDF, DOC, or DOCX only.
								Maximum {maxFileSizeMb}MB per file.
							</p>
						</div>

						<div class="mt-3">
							<label for="resume" class="block text-sm font-semibold text-slate-800">
								Resume
							</label>
							<label for="resume" class="mt-2 flex cursor-pointer flex-wrap items-center gap-3">
								<span
									class="btn btn-secondary btn-sm"
								>
									Choose Resume
								</span>
								<span data-file-name="resume" class="text-sm text-slate-700">No file selected</span>
								<button
									type="button"
									data-clear-file="resume"
									class="text-base font-semibold leading-none text-slate-500 hover:text-slate-700"
									style="display:none"
									aria-label="Remove selected resume"
								>
									&times;
								</button>
							</label>
							<input
								id="resume"
								name="resume"
								type="file"
								accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
								required
								style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;"
							/>
						</div>

						<div class="mt-3 flex flex-wrap items-center gap-3 pt-1">
							<div>
								<label for="cover-letter" class="block text-sm font-semibold text-slate-800">
									Cover Letter (optional)
								</label>
								<label for="cover-letter" class="mt-2 flex cursor-pointer flex-wrap items-center gap-3">
									<span
										class="btn btn-secondary btn-sm"
									>
										Choose Cover Letter
									</span>
									<span data-file-name="cover-letter" class="text-sm text-slate-700">
										No file selected
									</span>
									<button
										type="button"
										data-clear-file="cover-letter"
										class="text-base font-semibold leading-none text-slate-500 hover:text-slate-700"
										style="display:none"
										aria-label="Remove selected cover letter"
									>
										&times;
									</button>
								</label>
								<input
									id="cover-letter"
									name="cover_letter"
									type="file"
									accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
									style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;"
								/>
							</div>
						</div>

						<div data-netlify-recaptcha="true"></div>

						<div class="mt-6 flex flex-wrap items-center gap-3 pt-1">
							<button
								type="submit"
								class="btn btn-primary"
							>
								Submit Application
							</button>
							<a
								href="/careers"
								class="btn-link"
							>
								Back to Careers
							</a>
						</div>
					</form>
				</article>
			</div>
		</section>
	</main>
</Layout>

<script>
	const form = document.getElementById('career-application-form');
	if (form) {
		const postingInput = form.querySelector('#posting');
		const params = new URLSearchParams(window.location.search);
		const postingParam = params.get('posting');
		if (postingInput && postingParam) postingInput.value = postingParam;

		const allowedTypes = new Set([
			'application/pdf',
			'application/msword',
			'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
		]);
		const allowedExtensions = ['.pdf', '.doc', '.docx'];
		const maxFileSizeBytes = 5 * 1024 * 1024;

		const validateFileInput = (input) => {
			const file = input?.files?.[0];
			if (!file) return true;
			const lowerName = file.name.toLowerCase();
			const validExtension = allowedExtensions.some((ext) => lowerName.endsWith(ext));
			const validType = allowedTypes.has(file.type) || file.type === '';

			if ((!validExtension && !validType) || file.size > maxFileSizeBytes) {
				const errorText =
					file.size > maxFileSizeBytes
						? 'Each file must be 5MB or less.'
						: 'Only PDF, DOC, and DOCX files are allowed.';
				input.setCustomValidity(errorText);
				input.reportValidity();
				return false;
			}

			input.setCustomValidity('');
			return true;
		};

		const resumeInput = form.querySelector('#resume');
		const coverLetterInput = form.querySelector('#cover-letter');
		const resumeFileName = form.querySelector('[data-file-name="resume"]');
		const coverLetterFileName = form.querySelector('[data-file-name="cover-letter"]');
		const resumeClearButton = form.querySelector('[data-clear-file="resume"]');
		const coverLetterClearButton = form.querySelector('[data-clear-file="cover-letter"]');

		const updateFileName = (input, textNode, clearButton) => {
			if (!textNode) return;
			const file = input?.files?.[0];
			textNode.textContent = file ? file.name : 'No file selected';
			if (clearButton) clearButton.style.display = file ? 'inline-flex' : 'none';
		};

		for (const input of [resumeInput, coverLetterInput]) {
			if (!input) continue;
			input.addEventListener('change', () => {
				validateFileInput(input);
				if (input === resumeInput) updateFileName(resumeInput, resumeFileName, resumeClearButton);
				if (input === coverLetterInput)
					updateFileName(coverLetterInput, coverLetterFileName, coverLetterClearButton);
			});
		}

		const clearSelectedFile = (input, textNode, clearButton) => {
			if (!input) return;
			input.value = '';
			input.setCustomValidity('');
			updateFileName(input, textNode, clearButton);
		};

		if (resumeClearButton) {
			resumeClearButton.addEventListener('click', () =>
				clearSelectedFile(resumeInput, resumeFileName, resumeClearButton)
			);
		}

		if (coverLetterClearButton) {
			coverLetterClearButton.addEventListener('click', () =>
				clearSelectedFile(coverLetterInput, coverLetterFileName, coverLetterClearButton)
			);
		}

		form.addEventListener('submit', (event) => {
			const resumeOk = validateFileInput(resumeInput);
			const coverOk = validateFileInput(coverLetterInput);
			if (!resumeOk || !coverOk) event.preventDefault();
		});
	}
</script>

