---
import Layout from '../../layouts/Layout.astro';

const defaultPosting = '';
const maxFileSizeMb = 5;
---

<Layout
	title="Application Form | Financial Decisions Careers"
	description="Submit a career application to Financial Decisions."
>
	<main class="careers-application-page page-shell">
		<section class="careers-application-section page-section-soft no-divider min-h-[60vh] reveal">
			<div class="page-container page-container--content py-10 sm:py-12">
				<article class="careers-application-card ui-card news-card p-6 sm:p-8">
					<h2 class="inner-page-section-title">Application Form</h2>
					<p class="inner-page-body mt-2">
						Use this form to apply for a specific posting. General applications should be sent
						by email to{' '}
						<a href="mailto:fdi@financialdecisions.ca" class="btn-link">
							fdi@financialdecisions.ca
						</a>
						.
					</p>

					<form
						class="mt-6 space-y-5"
						name="career-application"
						method="POST"
						action="/careers/thank-you"
						data-netlify="true"
						data-netlify-honeypot="bot-field"
						data-netlify-recaptcha="true"
						enctype="multipart/form-data"
						id="career-application-form"
					>
						<input type="hidden" name="form-name" value="career-application" />
						<p class="hidden">
							<label>
								Do not fill this out if you are human:
								<input name="bot-field" />
							</label>
						</p>

						<div>
							<label for="name" class="block text-sm font-semibold text-[color:var(--ink-strong)]">Name</label>
							<input
								id="name"
								name="name"
								type="text"
								required
								class="mt-2 w-full rounded-md border border-[rgba(var(--ink-shadow-rgb),0.18)] px-3 py-2 text-sm text-[color:var(--ink-heading)] outline-none transition focus:border-[color:var(--accent)]"
							/>
						</div>

						<div>
							<label for="posting" class="block text-sm font-semibold text-[color:var(--ink-strong)]">Posting</label>
							<input
								id="posting"
								name="posting"
								type="text"
								value={defaultPosting}
								placeholder="Title of the role you are applying for"
								required
								class="mt-2 w-full rounded-md border border-[rgba(var(--ink-shadow-rgb),0.18)] px-3 py-2 text-sm text-[color:var(--ink-heading)] outline-none transition focus:border-[color:var(--accent)]"
							/>
						</div>

						<div>
							<label for="email" class="block text-sm font-semibold text-[color:var(--ink-strong)]">Email</label>
							<input
								id="email"
								name="email"
								type="email"
								required
								class="mt-2 w-full rounded-md border border-[rgba(var(--ink-shadow-rgb),0.18)] px-3 py-2 text-sm text-[color:var(--ink-heading)] outline-none transition focus:border-[color:var(--accent)]"
							/>
						</div>

						<div>
							<label for="message" class="block text-sm font-semibold text-[color:var(--ink-strong)]">
								Message (optional)
							</label>
							<textarea
								id="message"
								name="message"
								rows="6"
								class="mt-2 w-full rounded-md border border-[rgba(var(--ink-shadow-rgb),0.18)] px-3 py-2 text-sm text-[color:var(--ink-heading)] outline-none transition focus:border-[color:var(--accent)]"
							></textarea>
						</div>

						<div class="mt-3">
							<p class="block text-sm font-semibold text-[color:var(--ink-strong)]">
								Add resume and cover letter
							</p>
							<p class="mt-1 text-xs text-[color:var(--ink-body)]">
								Resume is required. Cover letter is optional. PDF, DOC, or DOCX only.
								Maximum {maxFileSizeMb}MB per file.
							</p>
						</div>

						<div class="mt-3">
							<label for="resume" class="block text-sm font-semibold text-[color:var(--ink-strong)]">
								Resume
							</label>
							<label for="resume" class="mt-2 flex cursor-pointer flex-wrap items-center gap-3">
								<span
									class="btn btn-secondary btn-sm"
								>
									Choose Resume
								</span>
								<span data-file-name="resume" class="text-sm text-[color:var(--ink-body)]">No file selected</span>
								<button
									type="button"
									data-clear-file="resume"
									class="text-base font-semibold leading-none text-[color:var(--ink-muted)] hover:text-[color:var(--ink-body)]"
									style="display:none"
									aria-label="Remove selected resume"
								>
									&times;
								</button>
							</label>
							<input
								id="resume"
								name="resume"
								type="file"
								accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
								required
								style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;"
							/>
						</div>

						<div class="mt-3 flex flex-wrap items-center gap-3 pt-1">
							<div>
								<label for="cover-letter" class="block text-sm font-semibold text-[color:var(--ink-strong)]">
									Cover Letter (optional)
								</label>
								<label for="cover-letter" class="mt-2 flex cursor-pointer flex-wrap items-center gap-3">
									<span
										class="btn btn-secondary btn-sm"
									>
										Choose Cover Letter
									</span>
									<span data-file-name="cover-letter" class="text-sm text-[color:var(--ink-body)]">
										No file selected
									</span>
									<button
										type="button"
										data-clear-file="cover-letter"
										class="text-base font-semibold leading-none text-[color:var(--ink-muted)] hover:text-[color:var(--ink-body)]"
										style="display:none"
										aria-label="Remove selected cover letter"
									>
										&times;
									</button>
								</label>
								<input
									id="cover-letter"
									name="cover_letter"
									type="file"
									accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
									style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;"
								/>
							</div>
						</div>

						<div data-netlify-recaptcha="true"></div>

						<div class="mt-6 flex flex-wrap items-center gap-3 pt-1">
							<button
								type="submit"
								class="btn btn-primary"
							>
								Submit Application
							</button>
							<a
								href="/careers"
								class="btn-link"
							>
								Back to Careers
							</a>
						</div>
					</form>
				</article>
			</div>
		</section>
	</main>
</Layout>

<style>
	.careers-application-page {
		background:
			linear-gradient(180deg, rgba(var(--surface-page-tint-rgb), 0.88) 0%, rgba(var(--white-rgb), 1) 28rem),
			var(--surface-page);
	}

	.careers-application-section {
		background: transparent;
	}

	.careers-application-card {
		max-width: 52rem;
		margin-inline: auto;
		border-radius: var(--radius-md);
		border-color: rgba(var(--accent-rgb), 0.18);
		background: linear-gradient(
			180deg,
			rgba(var(--white-rgb), 0.96) 0%,
			rgba(var(--surface-warm-rgb), 0.88) 100%
		);
		box-shadow: var(--shadow-lg);
	}

	.careers-application-card:hover {
		transform: none;
		box-shadow: var(--shadow-lg);
	}

	.careers-application-card .inner-page-section-title {
		padding-bottom: 1rem;
		border-bottom: 1px solid rgba(var(--accent-rgb), 0.16);
	}

	#career-application-form label,
	#career-application-form p {
		color: var(--ink-soft);
	}

	#career-application-form input[type='text'],
	#career-application-form input[type='email'],
	#career-application-form textarea {
		border-color: rgba(var(--accent-rgb), 0.28);
		border-radius: var(--radius-sm);
		background-color: rgba(var(--white-rgb), 0.92);
		padding: 0.62rem 0.78rem;
		line-height: 1.5;
	}

	#career-application-form input[type='text']:focus-visible,
	#career-application-form input[type='email']:focus-visible,
	#career-application-form textarea:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
		border-color: rgba(var(--accent-rgb), 0.45);
	}
</style>

<script>
	const form = document.getElementById('career-application-form');
	if (form) {
		const postingInput = form.querySelector('#posting');
		const params = new URLSearchParams(window.location.search);
		const postingParam = params.get('posting');
		if (postingInput && postingParam) postingInput.value = postingParam;

		const allowedTypes = new Set([
			'application/pdf',
			'application/msword',
			'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
		]);
		const allowedExtensions = ['.pdf', '.doc', '.docx'];
		const maxFileSizeBytes = 5 * 1024 * 1024;

		const validateFileInput = (input) => {
			const file = input?.files?.[0];
			if (!file) return true;
			const lowerName = file.name.toLowerCase();
			const validExtension = allowedExtensions.some((ext) => lowerName.endsWith(ext));
			const validType = allowedTypes.has(file.type) || file.type === '';

			if ((!validExtension && !validType) || file.size > maxFileSizeBytes) {
				const errorText =
					file.size > maxFileSizeBytes
						? 'Each file must be 5MB or less.'
						: 'Only PDF, DOC, and DOCX files are allowed.';
				input.setCustomValidity(errorText);
				input.reportValidity();
				return false;
			}

			input.setCustomValidity('');
			return true;
		};

		const resumeInput = form.querySelector('#resume');
		const coverLetterInput = form.querySelector('#cover-letter');
		const resumeFileName = form.querySelector('[data-file-name="resume"]');
		const coverLetterFileName = form.querySelector('[data-file-name="cover-letter"]');
		const resumeClearButton = form.querySelector('[data-clear-file="resume"]');
		const coverLetterClearButton = form.querySelector('[data-clear-file="cover-letter"]');

		const updateFileName = (input, textNode, clearButton) => {
			if (!textNode) return;
			const file = input?.files?.[0];
			textNode.textContent = file ? file.name : 'No file selected';
			if (clearButton) clearButton.style.display = file ? 'inline-flex' : 'none';
		};

		for (const input of [resumeInput, coverLetterInput]) {
			if (!input) continue;
			input.addEventListener('change', () => {
				validateFileInput(input);
				if (input === resumeInput) updateFileName(resumeInput, resumeFileName, resumeClearButton);
				if (input === coverLetterInput)
					updateFileName(coverLetterInput, coverLetterFileName, coverLetterClearButton);
			});
		}

		const clearSelectedFile = (input, textNode, clearButton) => {
			if (!input) return;
			input.value = '';
			input.setCustomValidity('');
			updateFileName(input, textNode, clearButton);
		};

		if (resumeClearButton) {
			resumeClearButton.addEventListener('click', () =>
				clearSelectedFile(resumeInput, resumeFileName, resumeClearButton)
			);
		}

		if (coverLetterClearButton) {
			coverLetterClearButton.addEventListener('click', () =>
				clearSelectedFile(coverLetterInput, coverLetterFileName, coverLetterClearButton)
			);
		}

		form.addEventListener('submit', (event) => {
			const resumeOk = validateFileInput(resumeInput);
			const coverOk = validateFileInput(coverLetterInput);
			if (!resumeOk || !coverOk) event.preventDefault();
		});
	}
</script>

