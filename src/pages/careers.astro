---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

const postings = [];
---

<Layout
	title="Careers | Financial Decisions"
	description="View current career opportunities and general application information for Financial Decisions."
>
	<main class="careers-page page-shell">
		<section class="careers-section page-section-soft min-h-[60vh] reveal">
			<div class="page-container page-container--content page-section--tight-top">
				<div class="careers-shell page-stack--lg">
					<Hero
						variant="page"
						eyebrow="Careers"
						title="Careers at Financial Decisions"
						subtitle="We periodically share openings here. If there is not a current posting that matches your background, you are still welcome to submit a general application."
						image="/images/Meeting.jpg"
						imageAlt="Financial Decisions meeting with clients"
						imageWidth="578"
						imageHeight="381"
						className="careers-header"
					>
						<p slot="meta" class="inner-page-meta careers-header-meta">
							{postings.length > 0
								? `${postings.length} current ${postings.length === 1 ? 'opening' : 'openings'}`
								: 'No current openings at this time'}
						</p>
					</Hero>

					<section class="careers-overview-grid" aria-label="Career opportunities">
						<article class="careers-surface careers-status-card ui-card">
							<div class="careers-card-header">
								<p class="careers-card-eyebrow">Current Openings</p>
								{postings.length > 0 && (
									<span class="careers-card-count">
										{postings.length} {postings.length === 1 ? 'role' : 'roles'}
									</span>
								)}
							</div>

							{postings.length > 0 ? (
								<div class="careers-posting-grid">
									{postings.map((posting) => (
										<article class="careers-posting-card">
											<h3 class="inner-page-item-title">{posting.title}</h3>
											<p class="inner-page-body careers-posting-copy">{posting.summary}</p>
											<a
												href={`/careers/apply?posting=${encodeURIComponent(posting.title)}`}
												class="btn btn-secondary mt-4"
											>
												Apply to This Posting
											</a>
										</article>
									))}
								</div>
							) : (
								<div class="careers-empty-state">
									<h2 class="careers-panel-title">No job postings are currently listed.</h2>
									<p class="inner-page-body careers-empty-copy">
										We update this page when opportunities become available. In the meantime,
										candidates who believe they may be a strong fit for the firm are welcome to
										introduce themselves by email.
									</p>
								</div>
							)}
						</article>

						<aside class="careers-surface careers-apply-card ui-card">
							<p class="careers-card-eyebrow">General Application</p>
							<h2 class="careers-panel-title">Interested in future opportunities?</h2>
							<p class="inner-page-body careers-apply-copy">
								Please email your background, experience, and why you may be a good fit for
								Financial Decisions.
							</p>
							<a
								href="mailto:fdi@financialdecisions.ca"
								class="btn btn-primary no-link-style careers-apply-button"
							>
								<span>Email fdi@financialdecisions.ca</span>
							</a>
							<p class="careers-apply-note">
								Specific posted roles can still be submitted through the application form linked
								from each opening.
							</p>
						</aside>
					</section>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.careers-page {
		background:
			linear-gradient(180deg, rgba(var(--surface-page-tint-rgb), 0.88) 0%, rgba(var(--white-rgb), 1) 28rem),
			var(--surface-page);
	}

	.careers-section {
		background: transparent;
	}

	.careers-shell {
		max-width: 66rem;
		margin-inline: auto;
	}

	:global(.careers-header) {
		padding-bottom: clamp(1.4rem, 2.7vw, 2rem);
		border-bottom: 1px solid rgba(var(--accent-rgb), 0.16);
	}

	.careers-header-meta {
		font-size: var(--text-meta);
		font-weight: 600;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: var(--accent-dark);
	}

	.careers-overview-grid {
		display: grid;
		gap: 1rem;
	}

	.careers-surface {
		padding: clamp(1.3rem, 2.4vw, 1.75rem);
		border-radius: var(--radius-xl);
		border-color: rgba(var(--accent-rgb), 0.16);
		background: linear-gradient(
			180deg,
			rgba(var(--white-rgb), 0.96) 0%,
			rgba(var(--surface-warm-rgb), 0.86) 100%
		);
		box-shadow: 0 16px 34px rgba(var(--ink-shadow-rgb), 0.05);
	}

	.careers-surface:hover {
		transform: none;
		box-shadow: 0 16px 34px rgba(var(--ink-shadow-rgb), 0.05);
	}

	.careers-card-header {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: space-between;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.careers-card-eyebrow {
		margin: 0;
		color: var(--accent-dark);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.14em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.careers-card-count {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2rem;
		padding: 0.35rem 0.75rem;
		border: 1px solid rgba(var(--accent-rgb), 0.14);
		border-radius: var(--radius-full);
		background: rgba(var(--surface-band-rgb), 0.48);
		color: var(--ink-muted);
		font-size: 0.8rem;
		font-weight: 600;
		line-height: 1.2;
	}

	.careers-panel-title {
		margin: 0;
		font-size: var(--text-compact-section-title);
		font-weight: 600;
		line-height: 1.12;
		letter-spacing: -0.028em;
		color: var(--ink-heading);
		text-wrap: balance;
	}

	.careers-empty-state {
		display: grid;
		gap: 0.85rem;
		max-width: 37rem;
	}

	.careers-empty-copy {
		max-width: 34rem;
		line-height: 1.82;
	}

	.careers-posting-grid {
		display: grid;
		gap: 0.9rem;
	}

	.careers-posting-card {
		padding: 1.1rem 1.15rem 1.2rem;
		border: 1px solid rgba(var(--accent-rgb), 0.12);
		border-radius: var(--radius-lg);
		background: rgba(var(--white-rgb), 0.72);
	}

	.careers-posting-copy {
		margin-top: 0.65rem;
		line-height: 1.72;
	}

	.careers-apply-card {
		display: grid;
		align-content: start;
		gap: 0.9rem;
	}

	.careers-apply-copy {
		max-width: 28rem;
		line-height: 1.8;
	}

	.careers-apply-button {
		margin-top: 0.2rem;
		width: fit-content;
	}

	.careers-apply-note {
		margin: 0;
		padding-top: 0.95rem;
		border-top: 1px solid rgba(var(--accent-rgb), 0.12);
		font-size: var(--text-small);
		line-height: 1.7;
		color: var(--ink-body);
	}

	@media (min-width: 900px) {
		.careers-overview-grid {
			grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
			align-items: start;
		}
	}

	@media (max-width: 639px) {
		.careers-apply-button {
			width: 100%;
		}
	}
</style>

