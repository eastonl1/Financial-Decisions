---
import Layout from '../layouts/Layout.astro';

const postings = [];
---

<Layout>
	<main class="page-shell">
		<section class="page-section-soft min-h-[60vh] reveal">
			<div class="page-container page-container--content page-section--tight-top">
				<div class="page-stack--lg">
					<section class="job-card ui-card page-stack">
						<h2 class="careers-panel-title">Current Job Postings</h2>
						{postings.length > 0 ? (
							<div class="mt-5 grid gap-4 sm:grid-cols-2">
								{postings.map((posting) => (
									<article class="ui-card p-5">
										<h3 class="inner-page-item-title">{posting.title}</h3>
										<p class="inner-page-body mt-2">{posting.summary}</p>
										<a
											href={`/careers/apply?posting=${encodeURIComponent(posting.title)}`}
											class="btn btn-secondary mt-4"
										>
											Apply to This Posting
										</a>
									</article>
								))}
							</div>
						) : (
							<p class="job-empty page-subtext mt-4">
								There are currently no job postings.
							</p>
						)}
					</section>

					<section class="job-card ui-card page-stack">
						<h2 class="careers-panel-title">
							Looking to apply anyway?
						</h2>
						<p class="page-subtext mt-2">
							Tell us why you may be a good fit for our team.
						</p>
						<p class="page-subtext mt-4">
							Please email us at <a href="mailto:fdi@financialdecisions.ca" class="break-all font-medium text-[color:var(--accent)] hover:underline sm:break-normal">fdi@financialdecisions.ca</a>
						</p>
					</section>
				</div>
			</div>
		</section>
	</main>
</Layout>

<style>
	.careers-panel-title {
		font-size: clamp(1.7rem, 2.6vw, 2.2rem);
		font-weight: 600;
		line-height: 1.12;
		letter-spacing: -0.028em;
		color: #0f172a;
		text-wrap: balance;
	}
</style>

