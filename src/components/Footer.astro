---
const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/insights", label: "Newsletters" },
  { href: "/resources", label: "Resources" },
  { href: "/client-access", label: "Client Access" },
  { href: "/contact", label: "Contact Us" },
  { href: "/careers", label: "Careers" },
];
---

<footer class="site-footer">
  <div class="page-container page-container--content py-8 sm:py-10">
    <div class="flex flex-col gap-6 md:flex-row md:items-start md:justify-between">
      <div class="flex items-center gap-3">
        <div class="rounded-full bg-white p-2 shadow-sm ring-1 ring-[color:var(--accent-muted)]">
          <img
            src="/images/Logo.jpg"
            alt="Financial Decisions logo"
            class="h-14 w-14 rounded-sm object-contain"
            width="56"
            height="56"
            loading="lazy"
            decoding="async"
          />
        </div>
        <div>
          <p class="text-base font-semibold text-slate-900">Financial Decisions</p>
          <p class="mt-1 text-sm text-slate-700">
            Independent financial planning and investment guidance.
          </p>
        </div>
      </div>

      <div class="flex flex-col items-start md:items-end md:text-right">
        <p class="footer-title">Explore</p>
        <div class="mt-3 flex flex-wrap justify-start gap-x-4 gap-y-2 text-sm md:justify-end">
          {links.map((link) => (
            <a href={link.href} class="footer-link">
              {link.label}
            </a>
          ))}
        </div>
        <a
          href="https://www.linkedin.com/company/financial-decisions-inc./"
          class="footer-link mt-3 inline-flex items-center gap-2 text-sm"
          target="_blank"
          rel="noopener"
        >
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            class="h-4 w-4 fill-current"
          >
            <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45z" />
          </svg>
          LinkedIn
        </a>
      </div>
    </div>

    <div class="mt-6 border-t border-[color:var(--accent-muted)] pt-3 text-xs text-slate-600">
      <p>&copy; {new Date().getFullYear()} Financial Decisions. All rights reserved.</p>
    </div>
  </div>
</footer>
