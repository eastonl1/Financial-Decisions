---
const internalLinks = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/insights", label: "Newsletters" },
  { href: "/resources", label: "Resources" },
  { href: "/client-access", label: "Client Access" },
  { href: "/contact", label: "Contact Us" },
  { href: "/careers", label: "Careers" },
];

const externalLinks = [
  {
    href: "https://www.linkedin.com/company/financial-decisions-inc./",
    label: "LinkedIn",
  },
];
---

<footer class="site-footer">
  <div class="page-container page-container--content site-footer__container">
    <div class="site-footer__main">
      <div class="site-footer__brand">
        <div class="site-footer__brand-mark" aria-hidden="true">
          <picture>
            <source srcset="/images/logo-transparent.webp" type="image/webp" />
            <img
              src="/images/logo-transparent.png"
              alt=""
              class="site-footer__logo"
              width="475"
              height="234"
              loading="lazy"
              decoding="async"
            />
          </picture>
        </div>
        <div class="site-footer__brand-copy">
          <p class="site-footer__brand-name">Financial Decisions</p>
          <p>Independent financial planning services</p>
        </div>
      </div>

      <div class="site-footer__column">
        <p class="footer-title">Explore</p>
        <ul class="site-footer__link-list" aria-label="Footer internal navigation">
          {internalLinks.map((link) => (
            <li><a href={link.href} class="footer-link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="site-footer__column">
        <p class="footer-title">Contact</p>
        <p class="site-footer__text-block site-footer__text-block--contact">
          <a href="tel:7055257526" class="footer-link">705-525-PLAN (7526)</a>
          <a href="mailto:fdi@financialdecisions.ca" class="footer-link">fdi@financialdecisions.ca</a>
        </p>
        <p class="site-footer__text-block site-footer__text-block--address">
          <a
            href="https://www.google.com/maps/search/?api=1&query=1546%20Bellevue%20Avenue%2C%20Sudbury%2C%20ON%2C%20P3B%203G2"
            target="_blank"
            rel="noopener"
            class="footer-link"
          >
            1546 Bellevue Avenue<br />
            Sudbury, ON P3B 3G2
          </a>
        </p>
        <div class="site-footer__follow-block">
          <p class="footer-title">Follow</p>
          <ul class="site-footer__link-list" aria-label="Footer external links">
            {externalLinks.map((link) => (
              <li>
                <a href={link.href} class="footer-link" target="_blank" rel="noopener">{link.label}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <div class="site-footer__bottom">
      <p>&copy; {new Date().getFullYear()} Financial Decisions. All rights reserved.</p>
      <p>
        <a href="https://eastonlindsay.com" target="_blank" rel="noopener" class="footer-link">
          Websites developed by eastonlindsay.com
        </a>
      </p>
    </div>
  </div>
</footer>
