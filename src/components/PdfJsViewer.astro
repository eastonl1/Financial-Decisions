---
interface Props {
	pdfUrl: string;
	title?: string;
}

const { pdfUrl, title = 'PDF document' } = Astro.props;
---

<section
	data-pdfjs-viewer
	data-pdf-url={pdfUrl}
	data-pdf-title={title}
	class="rounded-lg border border-[color:var(--accent-muted)] bg-white p-4 sm:p-6"
>
	<div class="flex flex-wrap items-center gap-2">
		<button
			type="button"
			data-role="prev"
			class="inline-flex items-center rounded-md border border-[color:var(--accent-muted)] px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:border-[color:var(--accent)] disabled:cursor-not-allowed disabled:opacity-50"
		>
			Prev
		</button>
		<button
			type="button"
			data-role="next"
			class="inline-flex items-center rounded-md border border-[color:var(--accent-muted)] px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:border-[color:var(--accent)] disabled:cursor-not-allowed disabled:opacity-50"
		>
			Next
		</button>
		<p data-role="page-indicator" class="text-sm text-slate-600">Page 0 of 0</p>
		<div class="ml-auto flex items-center gap-2">
			<button
				type="button"
				data-role="zoom-out"
				class="inline-flex items-center rounded-md border border-[color:var(--accent-muted)] px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:border-[color:var(--accent)]"
				aria-label="Zoom out"
			>
				-
			</button>
			<p data-role="zoom-indicator" class="w-14 text-center text-sm text-slate-600">100%</p>
			<button
				type="button"
				data-role="zoom-in"
				class="inline-flex items-center rounded-md border border-[color:var(--accent-muted)] px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:border-[color:var(--accent)]"
				aria-label="Zoom in"
			>
				+
			</button>
		</div>
	</div>

	<p data-role="status" class="mt-3 text-sm text-slate-600">Loading...</p>

	<div data-role="canvas-wrap" class="mt-4 overflow-auto rounded-md border border-slate-200 bg-slate-50 p-2">
		<div class="mx-auto w-fit">
			<canvas data-role="canvas" class="block"></canvas>
		</div>
	</div>

	<div class="mt-4 flex flex-wrap items-center gap-2">
		<button
			type="button"
			data-role="prev"
			class="inline-flex items-center rounded-md border border-[color:var(--accent-muted)] px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:border-[color:var(--accent)] disabled:cursor-not-allowed disabled:opacity-50"
		>
			Prev
		</button>
		<button
			type="button"
			data-role="next"
			class="inline-flex items-center rounded-md border border-[color:var(--accent-muted)] px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:border-[color:var(--accent)] disabled:cursor-not-allowed disabled:opacity-50"
		>
			Next
		</button>
		<p data-role="page-indicator" class="text-sm text-slate-600">Page 0 of 0</p>
		<div class="ml-auto flex items-center gap-2">
			<button
				type="button"
				data-role="zoom-out"
				class="inline-flex items-center rounded-md border border-[color:var(--accent-muted)] px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:border-[color:var(--accent)]"
				aria-label="Zoom out"
			>
				-
			</button>
			<p data-role="zoom-indicator" class="w-14 text-center text-sm text-slate-600">100%</p>
			<button
				type="button"
				data-role="zoom-in"
				class="inline-flex items-center rounded-md border border-[color:var(--accent-muted)] px-3 py-1.5 text-sm font-semibold text-slate-700 transition hover:border-[color:var(--accent)]"
				aria-label="Zoom in"
			>
				+
			</button>
		</div>
	</div>
</section>

<script type="module">
	const viewers = document.querySelectorAll('[data-pdfjs-viewer]:not([data-initialized])');

	for (const root of viewers) {
		root.setAttribute('data-initialized', 'true');
		initViewer(root);
	}

	async function initViewer(root) {
		const pdfUrl = root.getAttribute('data-pdf-url') || '';
		const resolvedPdfUrl = new URL(pdfUrl, window.location.origin).toString();
		const title = root.getAttribute('data-pdf-title') || 'PDF document';
		const prevButtons = root.querySelectorAll('[data-role="prev"]');
		const nextButtons = root.querySelectorAll('[data-role="next"]');
		const zoomOutButtons = root.querySelectorAll('[data-role="zoom-out"]');
		const zoomInButtons = root.querySelectorAll('[data-role="zoom-in"]');
		const pageIndicators = root.querySelectorAll('[data-role="page-indicator"]');
		const zoomIndicators = root.querySelectorAll('[data-role="zoom-indicator"]');
		const status = root.querySelector('[data-role="status"]');
		const canvasWrap = root.querySelector('[data-role="canvas-wrap"]');
		const canvas = root.querySelector('[data-role="canvas"]');
		const context = canvas.getContext('2d', { alpha: false });

		let pdf = null;
		let pageNumber = 0;
		let numPages = 0;
		let userZoom = 1;
		let renderTask = null;
		let resizeTimer = 0;

		const MIN_ZOOM = 0.5;
		const MAX_ZOOM = 2.5;
		const ZOOM_STEP = 0.1;

		function setStatus(message, isError = false) {
			status.textContent = message;
			status.className = isError ? 'mt-3 text-sm text-red-700' : 'mt-3 text-sm text-slate-600';
			status.hidden = !message;
		}

		function updateControls() {
			const pageText = numPages > 0 ? `Page ${pageNumber} of ${numPages}` : 'Page 0 of 0';
			const zoomText = `${Math.round(userZoom * 100)}%`;
			for (const indicator of pageIndicators) indicator.textContent = pageText;
			for (const indicator of zoomIndicators) indicator.textContent = zoomText;
			for (const button of prevButtons) button.disabled = !pdf || pageNumber <= 1;
			for (const button of nextButtons) button.disabled = !pdf || pageNumber >= numPages;
		}

		async function renderPage() {
			if (!pdf) return;

			try {
				setStatus('Loading...');
				updateControls();

				if (renderTask) {
					try {
						renderTask.cancel();
					} catch {}
				}

				const page = await pdf.getPage(pageNumber);
				const baseViewport = page.getViewport({ scale: 1 });
				const containerWidth = Math.max(canvasWrap.clientWidth - 16, 240);
				const fitScale = (containerWidth / baseViewport.width) * userZoom;
				const viewport = page.getViewport({ scale: fitScale });
				const dpr = window.devicePixelRatio || 1;

				canvas.width = Math.floor(viewport.width * dpr);
				canvas.height = Math.floor(viewport.height * dpr);
				canvas.style.width = `${Math.floor(viewport.width)}px`;
				canvas.style.height = `${Math.floor(viewport.height)}px`;
				context.setTransform(dpr, 0, 0, dpr, 0, 0);

				renderTask = page.render({ canvasContext: context, viewport });
				await renderTask.promise;
				renderTask = null;
				setStatus('');
			} catch (error) {
				if (error && error.name === 'RenderingCancelledException') return;
				setStatus(`Couldn't load this PDF. URL: ${pdfUrl}`, true);
				console.error('PDF render failed', { pdfUrl, error });
				canvas.width = 0;
				canvas.height = 0;
			}
		}

		function onResize() {
			window.clearTimeout(resizeTimer);
			resizeTimer = window.setTimeout(() => {
				renderPage();
			}, 150);
		}

		const goPrev = async () => {
			if (!pdf || pageNumber <= 1) return;
			pageNumber -= 1;
			updateControls();
			await renderPage();
		};

		const goNext = async () => {
			if (!pdf || pageNumber >= numPages) return;
			pageNumber += 1;
			updateControls();
			await renderPage();
		};

		const zoomOut = async () => {
			if (!pdf) return;
			userZoom = Math.max(MIN_ZOOM, Math.round((userZoom - ZOOM_STEP) * 10) / 10);
			updateControls();
			await renderPage();
		};

		const zoomIn = async () => {
			if (!pdf) return;
			userZoom = Math.min(MAX_ZOOM, Math.round((userZoom + ZOOM_STEP) * 10) / 10);
			updateControls();
			await renderPage();
		};

		for (const button of prevButtons) button.addEventListener('click', goPrev);
		for (const button of nextButtons) button.addEventListener('click', goNext);
		for (const button of zoomOutButtons) button.addEventListener('click', zoomOut);
		for (const button of zoomInButtons) button.addEventListener('click', zoomIn);

		window.addEventListener('resize', onResize);
		updateControls();
		canvas.setAttribute('aria-label', `${title} PDF page preview`);

		try {
			const pdfjsLib = await import('/pdfjs-dist/legacy/build/pdf.mjs');
			pdfjsLib.GlobalWorkerOptions.workerSrc = '/pdf.worker.min.mjs';

			const loadingTask = pdfjsLib.getDocument({ url: resolvedPdfUrl });
			pdf = await loadingTask.promise;
			numPages = pdf.numPages;
			pageNumber = 1;
			updateControls();
			await renderPage();
		} catch (error) {
			setStatus(`Couldn't load this PDF. URL: ${pdfUrl}`, true);
			console.error('PDF load failed', { pdfUrl, error });
		}
	}
</script>
