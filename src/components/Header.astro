---
const { pathname } = Astro.url;

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/insights", label: "Newsletters" },
  { href: "/resources", label: "Resources" },
  { href: "/client-access", label: "Client Access" },
  { href: "/contact", label: "Contact Us" },
  { href: "/careers", label: "Careers" },
];

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
};
---

<header data-site-header class="fixed left-0 right-0 top-0 z-50 border-b border-[color:var(--accent)] bg-[#f7f4f0]">
  <div class="container">
    <div class="flex items-center justify-between px-4 pb-0 md:px-0">
      <!-- Brand -->
      <a href="/" class="inline-flex items-center gap-3">
        <img
          src="/images/Logo.jpg"
          alt="Financial Decisions logo"
          class="ml-4 -my-2 h-32 w-32 rounded-sm object-contain"
          width="128"
          height="128"
          loading="eager"
          decoding="async"
        />
      </a>

      <!-- Desktop Nav -->
      <nav aria-label="Primary" class="ml-8 hidden md:block">
        <ul class="flex flex-wrap items-center gap-x-6 gap-y-2 text-[1.02rem]">
          {links.map((l) => (
            <li>
              <a
                href={l.href}
                class:list={[
                  "nav-link px-1.5 py-1 transition",
                isActive(l.href) && "nav-link-active",
                ]}
                aria-current={isActive(l.href) ? "page" : undefined}
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Mobile Nav -->
      <div class="relative md:hidden">
        <button
          type="button"
          data-mobile-nav-toggle
          aria-controls="mobile-nav-menu"
          aria-expanded="false"
          aria-label="Open menu"
          class="inline-flex h-10 w-10 items-center justify-center rounded-md border border-[color:var(--accent-muted)] bg-white text-[color:var(--accent-dark)]"
        >
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5 fill-none stroke-current stroke-2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
        <div
          id="mobile-nav-menu"
          data-mobile-nav-menu
          data-open="false"
          class="pointer-events-none absolute right-0 top-12 z-50 w-64 max-h-0 -translate-y-1 overflow-hidden rounded-md border border-[color:var(--accent-muted)] bg-[#f7f4f0] opacity-0 shadow-sm transition-all duration-200 ease-out"
        >
          <nav aria-label="Mobile primary">
            <ul class="p-2">
              {links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class:list={[
                      "block rounded-md px-3 py-3 text-base font-medium text-slate-700",
                      isActive(l.href) && "nav-link-active",
                    ]}
                    aria-current={isActive(l.href) ? "page" : undefined}
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector('[data-site-header]');
  if (header && !header.dataset.mobileNavInitialized) {
    header.dataset.mobileNavInitialized = 'true';
    const toggle = header.querySelector('[data-mobile-nav-toggle]');
    const menu = header.querySelector('[data-mobile-nav-menu]');
    const links = menu ? menu.querySelectorAll('a') : [];

    const setOpen = (open) => {
      if (!toggle || !menu) return;
      menu.dataset.open = open ? 'true' : 'false';
      menu.classList.toggle('opacity-0', !open);
      menu.classList.toggle('-translate-y-1', !open);
      menu.classList.toggle('pointer-events-none', !open);
      menu.classList.toggle('max-h-0', !open);
      menu.classList.toggle('max-h-96', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    };

    const isOpen = () => menu?.dataset.open === 'true';

    toggle?.addEventListener('click', (event) => {
      event.stopPropagation();
      setOpen(!isOpen());
    });

    links.forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('click', (event) => {
      if (!isOpen()) return;
      if (!header.contains(event.target)) setOpen(false);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });
  }
</script>
