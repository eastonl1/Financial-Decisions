---
import Layout from './Layout.astro';
import Hero from '../components/Hero.astro';

interface Props {
	title: string;
	description?: string;
	pubDate: Date;
	updatedDate?: Date;
	readingTime: string;
	pdfPath?: string;
}

const { title, description, pubDate, updatedDate, readingTime, pdfPath } = Astro.props;

const formatDate = (value: Date) =>
	new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(
		new Date(value)
	);
const metaDescription =
	description && description.trim()
		? description
		: `Newsletter from Financial Decisions published ${formatDate(pubDate)}.`;
---

<Layout
	title={`${title} | Financial Decisions`}
	description={metaDescription}
	type="article"
>
	<main class="page-shell newsletter-post-page">
		<section class="newsletter-post-section reveal no-divider">
			<div class="page-container page-container--content page-section--tight-top">
				<article class="newsletter-post-shell page-stack--lg">
					<Hero
						variant="page"
						eyebrow="Newsletters"
						title={title}
						subtitle={description}
						className="newsletter-post-header"
						contentClass="newsletter-post-header__content"
					>
						<p slot="meta" class="inner-page-meta newsletter-post-meta">
							{formatDate(pubDate)} &middot; {readingTime}
							{updatedDate && (
								<span>
									&nbsp;&middot;&nbsp;Updated {formatDate(updatedDate)}
								</span>
							)}
						</p>
						<nav
							class="newsletter-post-masthead-actions"
							aria-label="Newsletter actions"
						>
							<a href="/insights" class="newsletter-post-back-link">
								Back to Newsletters
							</a>
							{pdfPath && (
								<a href={pdfPath} download class="btn btn-secondary btn-sm newsletter-post-pdf-link">
									Download PDF
								</a>
							)}
						</nav>
					</Hero>

					<div class="newsletter-post-content prose-newsletter max-w-none">
						<slot />
					</div>

					<nav
						class="newsletter-post-actions newsletter-post-actions--footer flex flex-wrap items-center gap-3"
						aria-label="Newsletter footer actions"
					>
						<a href="/insights" class="newsletter-post-back-link">
							Back to Newsletters
						</a>
						{pdfPath && (
							<a href={pdfPath} download class="btn btn-secondary btn-sm newsletter-post-pdf-link">
								Download PDF
							</a>
						)}
					</nav>
				</article>
			</div>
		</section>
	</main>
</Layout>

<style is:global>
	.newsletter-post-section {
		background: transparent;
	}

	.newsletter-post-section .page-section--tight-top {
		padding-top: clamp(0.65rem, 1.4vw, 1.15rem);
		padding-bottom: clamp(2.5rem, 4vw, 3.5rem);
	}

	.newsletter-post-page {
		background:
			linear-gradient(180deg, rgba(var(--surface-page-tint-rgb), 0.9) 0%, rgba(var(--white-rgb), 1) 22rem),
			var(--surface-page);
	}

	.newsletter-post-shell {
		margin-inline: auto;
		max-width: min(100%, var(--page-content-max-width));
		gap: clamp(0.8rem, 1.4vw, 1.1rem);
		padding: clamp(0.65rem, 1.3vw, 1rem) 0 clamp(2.5rem, 4vw, 3.4rem);
	}

	.page-header.newsletter-post-header {
		position: relative;
		max-width: none !important;
		width: 100%;
		padding: clamp(0.95rem, 1.8vw, 1.35rem) 0 clamp(1rem, 1.9vw, 1.45rem);
		border-top: 0;
		border-bottom: 1px solid rgba(var(--accent-rgb), 0.16);
		background: transparent;
		background-color: transparent;
		background-image: none;
	}

	.newsletter-post-header .page-header__content,
	.newsletter-post-header__content {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		grid-template-areas:
			'eyebrow'
			'title'
			'meta'
			'subtitle'
			'actions';
		row-gap: 0.75rem;
		max-width: none !important;
		width: 100%;
	}

	.newsletter-post-header .inner-page-eyebrow {
		grid-area: eyebrow;
	}

	.newsletter-post-header .page-title {
		grid-area: title;
		max-width: 14ch;
		font-size: var(--text-newsletter-title);
		line-height: 1.05;
	}

	.newsletter-post-header .page-header__meta {
		grid-area: meta;
	}

	.newsletter-post-meta {
		max-width: 34rem;
		padding-top: 0;
		border-top: 0;
		font-size: var(--text-meta);
		line-height: 1.55;
		color: var(--ink-muted);
	}

	.newsletter-post-header .page-subtext {
		grid-area: subtitle;
		margin-top: 0.1rem;
		max-width: 41rem;
	}

	.newsletter-post-header .page-header__body {
		grid-area: actions;
		margin-top: 0;
	}

	.newsletter-post-masthead-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
		margin-left: auto;
	}

	.newsletter-post-actions {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.75rem;
	}

	.newsletter-post-actions--footer {
		justify-self: start;
		justify-content: flex-start;
		width: 100%;
		padding-top: 1.35rem;
		border-top: 1px solid rgba(var(--accent-rgb), 0.16);
	}

	.newsletter-post-back-link {
		display: inline-flex;
		align-items: center;
		min-height: 2.25rem;
		color: var(--accent-dark);
		font-size: var(--text-meta);
		font-weight: 600;
		line-height: 1.2;
		text-decoration-line: underline;
		text-decoration-color: rgba(var(--accent-rgb), 0.28);
		text-underline-offset: 0.28rem;
	}

	.newsletter-post-back-link:hover {
		color: var(--accent-dark);
		text-decoration-color: currentColor;
	}

	.newsletter-post-pdf-link {
		border-color: rgba(var(--accent-rgb), 0.24);
	}

	.newsletter-post-shell > header,
	.newsletter-post-shell > .newsletter-post-content,
	.newsletter-post-shell > div,
	.newsletter-post-shell > nav {
		padding-inline: clamp(0.2rem, 1.8vw, 1rem);
	}

	@media (min-width: 768px) {
		.newsletter-post-header .page-header__content,
		.newsletter-post-header__content {
			grid-template-columns: minmax(0, 1fr) auto;
			grid-template-areas:
				'eyebrow actions'
				'title actions'
				'meta actions'
				'subtitle actions';
			column-gap: clamp(1.8rem, 4vw, 4rem);
			align-items: start;
		}

		.newsletter-post-masthead-actions {
			justify-self: end;
			align-self: start;
			justify-content: flex-end;
		}
	}

	@media (max-width: 640px) {
		.newsletter-post-section .page-container {
			padding-inline: 1rem;
		}

		.newsletter-post-section .newsletter-post-shell {
			border: none !important;
			border-radius: 0 !important;
			background: transparent !important;
			background-color: transparent !important;
			background-image: none !important;
			box-shadow: none !important;
			padding: 0 !important;
		}

		:global(.newsletter-post-header)::after {
			width: 100%;
		}

		.newsletter-post-section .newsletter-post-shell > header,
		.newsletter-post-section .newsletter-post-shell > .newsletter-post-content,
		.newsletter-post-section .newsletter-post-shell > div,
		.newsletter-post-section .newsletter-post-shell > nav {
			background: transparent !important;
			background-color: transparent !important;
			background-image: none !important;
			box-shadow: none !important;
		}

		:global(.newsletter-post-header) {
			padding-top: 0.85rem;
		}

		:global(.newsletter-post-header .page-title) {
			max-width: 100%;
		}

		.newsletter-post-masthead-controls,
		.newsletter-post-actions {
			justify-content: flex-start;
		}
	}
</style>
