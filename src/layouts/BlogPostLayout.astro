---
import Layout from './Layout.astro';
import Hero from '../components/Hero.astro';

interface Props {
	title: string;
	description?: string;
	pubDate: Date;
	updatedDate?: Date;
	readingTime: string;
	pdfPath?: string;
}

const { title, description, pubDate, updatedDate, readingTime, pdfPath } = Astro.props;

const formatDate = (value: Date) =>
	new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(
		new Date(value)
	);
---

<Layout>
	<main>
		<Hero
			title="Newsletters"
			subtitle="Posts and newsletters from the Financial Decisions team."
		/>

		<section class="bg-white reveal">
			<div class="container mx-auto max-w-4xl px-6 py-10 sm:py-12">
				<article class="space-y-7 rounded-lg border border-[color:var(--accent-muted)] bg-white p-6 sm:p-8">
					<header class="space-y-4">
						<p class="eyebrow text-[color:var(--accent)]">Newsletters</p>
						<h1 class="text-2xl font-semibold leading-tight tracking-tight text-slate-900 sm:text-3xl">{title}</h1>
						<p class="text-sm text-slate-700">
							{formatDate(pubDate)} &middot; {readingTime}
							{updatedDate && (
								<span>
									&nbsp;&middot;&nbsp;Updated {formatDate(updatedDate)}
								</span>
							)}
						</p>
						{description && <p class="max-w-2xl text-sm leading-7 text-slate-700">{description}</p>}
						<div class="flex flex-wrap items-center gap-3 border-t border-[color:var(--accent-muted)] pt-5">
							<a href="/insights" class="btn btn-primary">
								Back to Newsletters
							</a>
							{pdfPath && (
								<a href={pdfPath} download class="btn btn-secondary">
									Download PDF
								</a>
							)}
						</div>
					</header>

					<div class="newsletter-post-content max-w-none text-[0.95rem] leading-8 text-slate-700 [&_a]:text-[color:var(--accent)] [&_a]:underline-offset-4 hover:[&_a]:underline [&_h2]:mt-10 [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:leading-tight [&_h2]:text-slate-900 [&_h3]:mt-8 [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:leading-tight [&_h3]:text-slate-900 [&_p+p]:mt-5 [&_ul]:mt-5 [&_ul]:space-y-2 [&_li]:leading-8">
						<slot />
					</div>

					<div class="flex flex-wrap items-center gap-3 border-t border-[color:var(--accent-muted)] pt-5">
						<a href="/insights" class="btn btn-primary">
							Back to Newsletters
						</a>
						{pdfPath && (
							<a href={pdfPath} download class="btn btn-secondary">
								Download PDF
							</a>
						)}
					</div>
				</article>
			</div>
		</section>
	</main>
</Layout>

<style is:global>
	.newsletter-post-content .newsletter-issue-summary {
		margin: 0 0 1.75rem;
		padding: 1.55rem;
		border: 1px solid rgba(138, 107, 77, 0.18);
		border-radius: 1rem;
		background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
		box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
	}

	.newsletter-post-content .newsletter-issue-summary-note {
		margin: 0 0 0.7rem;
		color: #64748b;
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		line-height: 1.45;
		text-transform: uppercase;
	}

	.newsletter-post-content .newsletter-issue-summary-label {
		margin: 0;
		color: var(--accent-dark);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		line-height: 1.4;
		text-transform: uppercase;
	}

	.newsletter-post-content .newsletter-issue-summary-list {
		margin: 0.9rem 0 0;
		padding: 0;
		list-style: none;
		counter-reset: newsletter-issue-summary;
		display: grid;
		gap: 0.8rem 1.4rem;
		grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
	}

	.newsletter-post-content .newsletter-issue-summary-item {
		position: relative;
		margin: 0;
		padding: 0 0 0.85rem 2.2rem;
		border-bottom: 1px solid rgba(148, 163, 184, 0.22);
		color: #334155;
		font-size: 0.95rem;
		font-weight: 500;
		line-height: 1.45;
	}

	.newsletter-post-content .newsletter-issue-summary-item::before {
		counter-increment: newsletter-issue-summary;
		content: counter(newsletter-issue-summary, decimal-leading-zero);
		position: absolute;
		top: 0.05rem;
		left: 0;
		color: var(--accent);
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		line-height: 1.2;
	}

	.newsletter-post-content .newsletter-issue-summary-item:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.newsletter-post-content .newsletter-issue-summary-byline {
		margin: 1rem 0 0;
		padding-top: 0.9rem;
		border-top: 1px solid rgba(148, 163, 184, 0.18);
		color: #64748b;
		font-size: 0.92rem;
		font-style: italic;
		line-height: 1.6;
	}

	.newsletter-post-content section > img:not([style*='max-width']) {
		width: auto !important;
		max-width: min(100%, 44rem) !important;
		height: auto !important;
		margin-inline: auto !important;
	}

	@media (max-width: 640px) {
		.newsletter-post-content .newsletter-issue-summary {
			padding: 1.35rem;
		}

		.newsletter-post-content .newsletter-issue-summary-list {
			grid-template-columns: 1fr;
			gap: 0.6rem;
		}

		.newsletter-post-content .newsletter-issue-summary-item {
			padding-bottom: 0.6rem;
		}

		/* Older newsletter markdown uses layout tables; stack them on phones. */
		.newsletter-post-content table {
			display: block;
			width: 100% !important;
			border-spacing: 0 !important;
		}

		.newsletter-post-content table tbody,
		.newsletter-post-content table tr {
			display: block;
			width: 100% !important;
		}

		.newsletter-post-content table tr + tr {
			margin-top: 1.25rem;
		}

		.newsletter-post-content table td,
		.newsletter-post-content table th {
			display: block;
			width: 100% !important;
			padding-left: 0 !important;
			padding-right: 0 !important;
		}

		.newsletter-post-content table td + td,
		.newsletter-post-content table th + th {
			margin-top: 1.25rem;
		}
	}
</style>
