---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'

const defaultTitle = 'Financial Decisions | Independent Financial Planning'
const defaultDescription =
	'Independent financial planning services in Sudbury, Ontario, focused on investments, retirement, insurance, and long-term financial guidance.'
const defaultImage = '/images/office-painted.jpg'
const siteUrl = Astro.site ?? new URL('https://financialdecisions.ca')
const {
	title = defaultTitle,
	description = defaultDescription,
	image = defaultImage,
	type = 'website',
	heroPreload,
} = Astro.props

const canonicalUrl = new URL(Astro.url.pathname, siteUrl)
const imageUrl = new URL(image, siteUrl)
const logoUrl = new URL('/images/logo-transparent.png', siteUrl)
const localBusinessJson = {
	'@context': 'https://schema.org',
	'@type': ['LocalBusiness', 'FinancialService'],
	'@id': new URL('/#financial-decisions', siteUrl).toString(),
	name: 'Financial Decisions',
	url: siteUrl.toString(),
	logo: logoUrl.toString(),
	image: imageUrl.toString(),
	description: defaultDescription,
	telephone: '+1-705-525-7526',
	email: 'fdi@financialdecisions.ca',
	address: {
		'@type': 'PostalAddress',
		streetAddress: '1546 Bellevue Avenue',
		addressLocality: 'Sudbury',
		addressRegion: 'ON',
		postalCode: 'P3B 3G2',
		addressCountry: 'CA',
	},
	openingHoursSpecification: [
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
			opens: '09:00',
			closes: '17:00',
		},
	],
	sameAs: ['https://www.linkedin.com/company/financial-decisions-inc./'],
}
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Google tag (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-H6K866TMRM"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag() {
				window.dataLayer.push(arguments);
			}
			gtag('js', new Date());
			gtag('config', 'G-H6K866TMRM');
		</script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/images/logo-transparent.png" />
		<link rel="canonical" href={canonicalUrl.toString()} />
		{heroPreload && (
			<link
				rel="preload"
				as="image"
				href={heroPreload.href}
				type={heroPreload.type}
				fetchpriority="high"
			/>
		)}
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content={type} />
		<meta property="og:site_name" content="Financial Decisions" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl.toString()} />
		<meta property="og:image" content={imageUrl.toString()} />
		<meta property="og:image:width" content="1536" />
		<meta property="og:image:height" content="1024" />
		<meta property="og:locale" content="en_CA" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl.toString()} />
		<script type="application/ld+json" set:html={JSON.stringify(localBusinessJson)} />
	</head>
	<body>
		<Header />
		<slot />
		<Footer />
		<script is:inline>
			(() => {
				const targets = Array.from(
					document.querySelectorAll('.reveal, .reveal-image, .img-reveal, [data-reveal-immediate]')
				);
				if (!targets.length) return;

				// Respect reduced-motion users by bypassing all reveal transitions.
				if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
					targets.forEach((element) => {
						element.classList.add('is-visible');
						element.classList.remove('will-reveal');
					});
					return;
				}

				const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
				const revealBuffer = Math.max(64, viewportHeight * 0.08);
				const isInitiallyInView = (element) => {
					const rect = element.getBoundingClientRect();
					return rect.top <= viewportHeight - revealBuffer && rect.bottom >= -24;
				};

				if (!('IntersectionObserver' in window)) {
					targets.forEach((element) => element.classList.add('is-visible'));
					return;
				}

				const observer = new IntersectionObserver(
					(entries, activeObserver) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							entry.target.classList.remove('will-reveal');
							entry.target.classList.add('is-visible');
							activeObserver.unobserve(entry.target);
						});
					},
					{
						threshold: 0.16,
						rootMargin: '0px 0px -10% 0px',
					}
				);

				targets.forEach((element) => {
					if (element.hasAttribute('data-reveal-immediate') || isInitiallyInView(element)) {
						element.classList.add('is-visible');
						return;
					}

					// Only below-the-fold content gets the hidden baseline state.
					element.classList.add('will-reveal');
					observer.observe(element);
				});
			})();
		</script>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
</style>
