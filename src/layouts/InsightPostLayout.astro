---
import Layout from './Layout.astro';
const { frontmatter, Content } = Astro.props;
const date = frontmatter?.date
	? new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(
			frontmatter.date
		)
	: '';
---

<Layout>
	<main>
		<section class="bg-white">
			<div class="container mx-auto px-6 py-10 sm:py-12">
				<article class="insight-article mx-auto">
					<p class="eyebrow">Insights</p>
					<h1 class="mt-3 text-3xl font-semibold text-slate-900 sm:text-4xl">
						{frontmatter?.title}
					</h1>
					{date && <p class="mt-2 text-sm text-slate-600">{date}</p>}

					{frontmatter?.pdf && (
						<a
							href={frontmatter.pdf}
							class="mt-5 inline-flex items-center rounded-md border border-[color:var(--accent-muted)] bg-white px-4 py-2 text-sm font-semibold text-[color:var(--accent)] transition hover:border-[color:var(--accent)] hover:text-[color:var(--accent-dark)]"
						>
							Download PDF
						</a>
					)}

					<div class="prose-content mt-8">
						<Content />
					</div>

					<a
						href="/insights"
						class="mt-10 inline-flex items-center text-sm font-semibold text-[color:var(--accent)] hover:text-[color:var(--accent-dark)]"
					>
						Back to Insights
					</a>
				</article>
			</div>
		</section>
	</main>
</Layout>

<style>
	.insight-article {
		max-width: 720px;
	}

	.prose-content :global(h2) {
		margin-top: 1.75rem;
		font-size: 1.35rem;
		font-weight: 600;
		color: #0f172a;
	}

	.prose-content :global(p) {
		margin-top: 1rem;
		line-height: 1.75;
		color: #475569;
	}

	.prose-content :global(ul),
	.prose-content :global(ol) {
		margin-top: 1rem;
		padding-left: 1.25rem;
		color: #475569;
	}

	.prose-content :global(blockquote) {
		margin-top: 1.5rem;
		padding-left: 1rem;
		border-left: 3px solid rgba(138, 107, 77, 0.35);
		color: #475569;
	}

	.prose-content :global(img) {
		margin-top: 1.5rem;
		border-radius: 12px;
	}
</style>
